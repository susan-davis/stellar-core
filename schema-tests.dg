%% dgdebug -q schema-tests.dg schema.dg sectored-grid.dg utils.dg \
%% 		   unit.dg stdlib.dg

(list of tests [
	#coordinates
	#subsector
	#speed
	#warp-gradient
	#energy
	#crystals
	#shields
	#shield-levels
	#shield-level-north
	#shield-level-east
	#shield-level-south
	#shield-level-west
	#ammo
	#helm
	#throttle
	#throttle-gradient
	#destination
	#destination-subsector
	#destination-precisely
	#turn-mode
	#effective-turn-mode
	#effective-turn-mode-sublight
	#acceleration
	#drive-params
	#efficiency
	#cruising-speed
	#top-speed
	#class
	#ship-class
	#initialize
	#set-destination
	#set-destination-subsector
	#set-destination-precisely
	#set-helm
	#set-throttle-speed
	#set-throttle-speed-too-fast
	#set-throttle-gradient
	#set-throttle-gradient-too-fast
	#decrease-ammo
	#decrease-ammo-below-zero
	#decrease-energy
	#decrease-energy-below-zero
	#regenerate
	#regenerate-above-max
	#decrease-shields
	#decrease-shields-below-zero
	#regenerate-shields
	#regenerate-shields-above-max
	#accelerate
	#accelerate-too-fast
	#decelerate
	#systems-list
	#find-torpedoes
	#find-torpedo-1
	#dont-find-torpedo-3
	#arc-projector
	#arc-tractor
	#arc-mtd
	#value-projector
	#value-tractor
	#value-mtd
	#details-projector
	#details-tractor
	#details-mtd
	#repair-time-projector
	#repair-time-tractor
	#repair-time-mtd
	#repair-time-type-not-found
	#repair-time-id-not-found
	#set-repair-time-projector
	#set-repair-time-type-not-found
	#set-repair-time-id-not-found
	#increase-repair-time-tractor
	#increase-repair-time-mtd
	#decrease-repair-time-tractor
	#decrease-repair-time-beyond-zero
	#decrease-repair-time-mtd
	#destroy-tractor
	#repair-tractor
	#destroy-ship
	#test-ship-is-not-destroyed
	])

%% ----------------------------------------------------------------------

%% state = [ PositionX PositionY Heading Speed DestX DestY Helm Throttle
%% 		   	 Class Energy Crystals Ammo Shields [S1 S2 S3 S4] [ Systems ] ]

#test-ship
(grid object *)
(initial state [344 454 315 400 300 400 315 400 #cygnus-class])

(set up $)
	 (initial state $State)
	 (now) (* state $State)
	 (initialize * as #cygnus-class)
	 (decrease energy for * by 68)

#cygnus-class
(name *)	Cygnus
(type *)	fast scout
(* state [0 0 180 0 500 963 0 0
   		 	#cygnus-class 1000 4 10 500 [100 99 98 97]
			[[#projector 1 [360 #up] 100 141 0]
			[#torpedo 1 [1 8] 500 0 0]
			[#torpedo 2 [1 8] 500 0 0]
			[#tractor 1 360 250 0 800]
			[#sensor 2 [1 8] 2 0 0]
			[#sensor 1 [360 #up #down] 1 0 0]
			[#sensor 0 [360 #up #down] 1 0 0]
			[#mtd 1 #down 4 0 16383]
			[#shuttle 1 #south 10 0 0]
			]])

%% ----------------------------------------------------------------------

(test #coordinates)
	  (#test-ship coordinates into 3 4 5 6 5 5)

(test #subsector)
	  (#test-ship subsector into 3 4 5 6)

(test #speed)
	  (#test-ship speed 400)

(test #warp-gradient)
	  (#test-ship warp gradient 4)

(test #energy)
	  (#test-ship energy 932)

(test #crystals)
	  (#test-ship crystals 4)

(test #shields)
	  (#test-ship shields 500)

(test #shield-levels)
	  (#test-ship shield levels [100 99 98 97])

(test #shield-level-north)
	  (#test-ship shield level #north into 100)

(test #shield-level-east)
	  (#test-ship shield level #east into 99)

(test #shield-level-south)
	  (#test-ship shield level #south into 98)

(test #shield-level-west)
	  (#test-ship shield level #west into 97)

(test #ammo)
	  (#test-ship ammo 10)

(test #helm)
	  (#test-ship helm setting 315)

(test #throttle)
	  (#test-ship throttle setting 400)

(test #throttle-gradient)
	  (#test-ship throttle gradient 4)

(test #destination)
	  (#test-ship destination [300 400])

(test #destination-subsector)
	  (#test-ship destination 3 4 1 1)

(test #destination-precisely)
	  (#test-ship destination 3 4 1 1 1 1)

(test #turn-mode)
	  (#test-ship turn mode 180)

(test #effective-turn-mode)
	  (#test-ship effective turn mode 45)

(test #effective-turn-mode-sublight)
	  (accelerate #test-ship to speed 0)
	  (#test-ship effective turn mode 360)

(test #drive-params)
	  (#test-ship drive parameters [500 963])

(test #efficiency)
	  (#test-ship drive efficiency 500)

(test #cruising-speed)
	  (#test-ship cruising speed 6)

(test #top-speed)
	  (#test-ship top speed 9)

(test #acceleration)
	  (#test-ship acceleration 300)

(test #class)
	  (#test-ship class #cygnus-class)

(test #ship-class)
	  (collect words) (class #test-ship) (into $Words)
	  ($Words = [cygnus -class fast scout])

(test #initialize)
	  (initialize #test-ship as #cygnus-class)
	  (#test-ship class #cygnus-class)
	  (#test-ship energy 1000)
	  (#test-ship crystals 4)
	  (#test-ship shields 500)
	  (#test-ship shield levels [100 99 98 97])
	  (#test-ship ammo 10)

(test #set-destination)
	  (position for 4 5 6 7 into $Position)
	  (set destination for #test-ship to $Position)
	  (#test-ship destination 4 5 6 7)
	  (#test-ship heading 315)
	  (#test-ship helm setting 135)

(test #set-destination-subsector)
	  (set destination for #test-ship to 4 5 6 7)
	  (#test-ship destination $There)
	  ([454 564 | $] = $There)
	  (#test-ship helm setting 135)

(test #set-destination-precisely)
	  (set destination for #test-ship to 4 5 6 7 8 9)
	  (#test-ship destination 4 5 6 7 8 9)
	  (#test-ship helm setting 137)

(test #set-helm)
	  (set helm for #test-ship to 135)
	  (#test-ship helm setting 135)

(test #set-throttle-speed)
	  (set throttle for #test-ship to speed 610)
	  (#test-ship throttle setting 610)

(test #set-throttle-speed-too-fast)
	  (set throttle for #test-ship to speed 1099)
	  (#test-ship throttle setting 900)

(test #set-throttle-gradient)
	  (set throttle for #test-ship to gradient 6)
	  (#test-ship throttle setting 600)

(test #set-throttle-gradient-too-fast)
	  (set throttle for #test-ship to gradient 10)
	  (#test-ship throttle setting 900)

(test #decrease-ammo)
	  (decrease ammo for #test-ship by 3)
	  (#test-ship ammo 7)

(test #decrease-ammo-below-zero)
	  ~(decrease ammo for #test-ship by 11)

(test #decrease-energy)
	  (decrease energy for #test-ship by 32)
	  (#test-ship energy 900)

(test #decrease-energy-below-zero)
	  ~(decrease energy for #test-ship by 1001)

(test #regenerate)
	  (regenerate energy for #test-ship)
	  (#test-ship energy 972)

(test #regenerate-above-max)
	  (regenerate energy for #test-ship)
	  (regenerate energy for #test-ship)
	  (#test-ship energy 1000)

(test #decrease-shields)
	  (decrease shields for #test-ship by 50)
	  (#test-ship shields 450)

(test #decrease-shields-below-zero)
	  ~(decrease shields for #test-ship by 501)

(test #regenerate-shields)
	  (decrease shields for #test-ship by 50)
	  (#test-ship shields 450)
	  (regenerate shields for #test-ship by 50)
	  (#test-ship shields 500)

(test #regenerate-shields-above-max)
	  (decrease shields for #test-ship by 50)
	  (#test-ship shields 450)
	  (regenerate shields for #test-ship by 100)
	  (#test-ship shields 500)

(test #accelerate)
	  (accelerate #test-ship to speed 600)
	  (#test-ship speed 600)

(test #accelerate-too-fast)
	  (accelerate #test-ship to speed 1000)
	  (#test-ship speed 900)

(test #decelerate)
	  (accelerate #test-ship to speed 0)
	  (#test-ship speed 0)

(test #accelerate-gradient)
	  (accelerate #test-ship to gradient 6)
	  (#test-ship warp gradient 6)

(test #accelerate-gradient-too-fast)
	  (accelerate #test-ship to gradient 10)
	  (#test-ship warp gradient 9)

(test #decelerate-gradient)
	  (accelerate #test-ship to gradient 0)
	  (#test-ship speed 0)

(test #systems-list)
	  (#test-ship systems $List)
	  (length of $List into 9)

(test #find-torpedoes)
	  (find all #torpedo for #test-ship into $Torps)
	  (assert $Torps = [[#torpedo 1 [1 8] 500 0 0] [#torpedo 2 [1 8] 500 0 0]])

(test #find-torpedo-1)
	  (find #test-ship #torpedo 1 into [#torpedo 1 [1 8] 500 0 0])

(test #dont-find-torpedo-3)
	  ~(find #test-ship #torpedo 3 into $)

(test #arc-projector)
	  (#test-ship #projector 1 arc [360 #up])

(test #arc-tractor)
	  (#test-ship #tractor 1 arc 360)

(test #arc-mtd)
	  (#test-ship #mtd 1 arc #down)

(test #value-projector)
	  (#test-ship #projector 1 value 100)

(test #value-tractor)
	  (#test-ship #tractor 1 value 250)

(test #value-mtd)
	  (#test-ship #mtd 1 value 4)

(test #details-projector)
	  (#test-ship #projector 1 details 141)

(test #details-tractor)
	  (#test-ship #tractor 1 details 0)

(test #details-mtd)
	  (#test-ship #mtd 1 details 0)

(test #repair-time-projector)
      (#test-ship #projector 1 repair time 0)

(test #repair-time-tractor)
      (#test-ship #tractor 1 repair time 800)

(test #repair-time-mtd)
      (#test-ship #mtd 1 repair time 16383)

(test #repair-time-type-not-found)
	  ~(#test-ship #missile 1 repair time $)

(test #repair-time-id-not-found)
	  ~(#test-ship #projector 2 repair time $)

(test #set-repair-time-projector)
	  (#test-ship systems $Before)
	  (length of $Before into $LenBefore)
      (set repair time for #test-ship #projector 1 to 300)
	  (#test-ship #projector 1 repair time 300)
	  (#test-ship systems $After)
	  (length of $After into $LenAfter)
	  (assert $LenBefore = $LenAfter)

(test #set-repair-time-type-not-found)
%%      ~(set repair time for #test-ship #missile 1 to 300)

(test #set-repair-time-id-not-found)
%%      ~(set repair time for #test-ship #projector 2 to 300)

(test #increase-repair-time-tractor)
	  (#test-ship systems $Before)
	  (length of $Before into $LenBefore)
	  (increase repair time for #test-ship #tractor 1 by 200)
	  (#test-ship #tractor 1 repair time 1000)
	  (#test-ship systems $After)
	  (length of $After into $LenAfter)
	  (assert $LenBefore = $LenAfter)

(test #increase-repair-time-mtd)
	  (increase repair time for #test-ship #mtd 1 by 200)
	  (#test-ship #mtd 1 repair time 16383)

(test #decrease-repair-time-tractor)
	  (#test-ship systems $Before)
	  (length of $Before into $LenBefore)
	  (decrease repair time for #test-ship #tractor 1 by 200)
	  (#test-ship #tractor 1 repair time 600)
	  (#test-ship systems $After)
	  (length of $After into $LenAfter)
	  (assert $LenBefore = $LenAfter)

(test #decrease-repair-time-beyond-zero)
	  (decrease repair time for #test-ship #tractor 1 by 900)
	  (#test-ship #tractor 1 repair time 0)

(test #decrease-repair-time-mtd)
	  ~(decrease repair time for #test-ship #mtd 1 by 900)

(test #destroy-tractor)
	  (#test-ship systems $Before)
	  (length of $Before into $LenBefore)
	  (destroy #test-ship #tractor 1)
	  ~(decrease repair time for #test-ship #tractor 1 by 900)
	  (#test-ship systems $After)
	  (length of $After into $LenAfter)
	  (assert $LenBefore = $LenAfter)

(test #repair-tractor)
	  (#test-ship systems $Before)
	  (length of $Before into $LenBefore)
	  (repair #test-ship #tractor 1)
	  (#test-ship #tractor 1 repair time 0)
	  (#test-ship systems $After)
	  (length of $After into $LenAfter)
	  (assert $LenBefore = $LenAfter)

(test #destroy-ship)
	  (destroy #test-ship)
	  (#test-ship is destroyed)

(test #test-ship-is-not-destroyed)
	  ~(#test-ship is destroyed)
