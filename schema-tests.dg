%% dgdebug -u schema-tests.dg test-ships.dg schema.dg sector.dg grid.dg \
%% 		   	  utils.dg unit.dg stdlib.dg

(list of tests [
	#shields
	#shield-levels
	#shield-level-north
	#shield-level-east
	#shield-level-south
	#shield-level-west
	#ammo
	#systems-list
	#class-systems-list
	#damaged-systems
	#destroyed-systems
	#undamaged-systems
	#undestroyed-systems
	#damaged-systems-simple
	#destroyed-systems-simple
	#test-ship-isnt-simple
	#closest-target-is-simple
	#near-target-is-simple
	#class
	#ship-class
	#long-class
	#initialize
	#decrease-ammo
	#decrease-ammo-below-zero
	#decrease-shields
	#decrease-shields-below-zero
	#regenerate-shields
	#regenerate-shields-above-max
	#find-torpedoes
	#dont-find-damaged-torpedo
	#find-torpedo-1
	#dont-find-torpedo-3
	#arc-projector
	#arc-tractor
	#arc-mtd
	#value-projector
	#value-tractor
	#value-mtd
	#details-projector
	#details-tractor
	#details-mtd
	#repair-time-projector
	#repair-time-tractor
	#repair-time-mtd
	#repair-time-type-not-found
	#repair-time-id-not-found
	#set-repair-time-projector
	#set-repair-time-type-not-found
	#set-repair-time-id-not-found
	#increase-repair-time-tractor
	#increase-repair-time-mtd
	#decrease-repair-time-tractor
	#decrease-repair-time-beyond-zero
	#decrease-repair-time-mtd
	#repair-tractor
	#destroy-ship
	#test-ship-is-not-destroyed
	#test-ship-is-union
	#closest-target-is-quellan
	#near-target-is-quellan
	#far-target-is-quellan
	#distant-target-is-quellan
	#closest-target-is-hostile
	#near-target-is-hostile
	#far-target-is-hostile
	#distant-target-is-hostile
	#closest-target-finds-test-ship-hostile
	#closest-target-finds-near-target-friendly
	#closest-target-finds-far-target-friendly
	#closest-target-finds-distant-target-friendly
	#closest-target-in-sensor-range
	#near-target-in-sensor-range
	#far-target-in-sensor-range
	#distant-target-not-in-sensor-range
	#non-grid-object-not-in-sensor-range
	#closest-target-in-weapons-range
	#near-target-in-weapons-range
	#far-target-not-in-weapons-range
	#distant-target-not-in-weapons-range
	#non-grid-object-not-in-weapons-range
	#closest-target-in-matter-transmission-range
	#near-target-not-in-matter-transmission-range
	#far-target-not-in-matter-transmission-range
	#distant-target-not-in-matter-transmission-range
	#non-grid-object-not-in-matter-transmission-range
	#closest-in-sensor-range-of-near
	#closest-in-weapons-range-of-near
	#near-out-of-range-of-far
	#near-out-of-range-of-distant
	])

(reset randomness)

%% position = [X Y Heading Speed]
%% state = [Helm Throttle DestX DestY Class Energy Crystals Ammo Shields [Lvls]]
%% system = [Type ID RepairTime]

%% class  = [Efficiency Subspace TurnMode Accel Fleet MaxEnergy MaxCrystals
%% 		  	 MaxAmmo MaxShields [MaxLevels]]
%% system = [System ID Arcs Value Details]

%% ----------------------------------------------------------------------

(test #shields)
	  (#test-ship shields 500)

(test #shield-levels)
	  (#test-ship shield levels [100 99 98 97])

(test #shield-level-north)
	  (#test-ship shield level #north into 100)

(test #shield-level-east)
	  (#test-ship shield level #east into 99)

(test #shield-level-south)
	  (#test-ship shield level #south into 98)

(test #shield-level-west)
	  (#test-ship shield level #west into 97)

(test #ammo)
	  (#test-ship ammo 10)

(test #class)
	  (#test-ship class #cygnus-class)

(test #ship-class)
	  (collect words) (class #test-ship) (into $Words)
	  ($Words = [cygnus -class fast scout])

(test #long-class)
	  (collect words) (long class #test-ship) (into $Words)
	  ($Words = [stellar union cygnus -class fast scout])

(test #initialize)
	  (initialize #test-ship as #cygnus-class)
	  (#test-ship class #cygnus-class)
	  (#test-ship energy 1000)
	  (#test-ship crystals 4)
	  (#test-ship shields 500)
	  (#test-ship shield levels [100 99 98 97])
	  (#test-ship ammo 10)

(test #decrease-ammo)
	  (decrease ammo for #test-ship by 3)
	  (#test-ship ammo 7)

(test #decrease-ammo-below-zero)
	  ~(decrease ammo for #test-ship by 11)

(test #decrease-shields)
	  (decrease shields for #test-ship by 50)
	  (#test-ship shields 450)

(test #decrease-shields-below-zero)
	  ~(decrease shields for #test-ship by 501)

(test #regenerate-shields)
	  (decrease shields for #test-ship by 50)
	  (#test-ship shields 450)
	  (regenerate shields for #test-ship by 50)
	  (#test-ship shields 500)

(test #regenerate-shields-above-max)
	  (decrease shields for #test-ship by 50)
	  (#test-ship shields 450)
	  (regenerate shields for #test-ship by 100)
	  (#test-ship shields 500)

(test #systems-list)
	  (#test-ship systems $List)
	  (length of $List into 2)

(test #class-systems-list)
	  (#test-ship class systems $List)
	  (length of $List into 24)

(test #damaged-systems)
	  (#test-ship damaged systems [[#tractor 1 800]])

(test #destroyed-systems)
	  (#test-ship destroyed systems [[#mtd 1 16383]])

(test #undamaged-systems)
	  (#test-ship undamaged systems $List)
	  (length of $List into 22)

(test #undestroyed-systems)
	  (#test-ship undestroyed systems $List)
	  (length of $List into 23)

(test #damaged-systems-simple)
	  (#closest-target damaged systems [])

(test #destroyed-systems-simple)
	  (#closest-target destroyed systems [])

(test #test-ship-isnt-simple)
	  ~(#test-ship is simple)

(test #closest-target-is-simple)
	  (#closest-target is simple)

(test #near-target-is-simple)
	  (#near-target is simple)

(test #find-torpedoes)
	  (find undamaged #torpedo for #test-ship into $Torps)
	  (assert $Torps = [[#torpedo 1 [1 8] 1 500]
	  		  		    [#torpedo 2 [1 8] 1 500]])

(test #dont-find-damaged-torpedo)
	  (increase repair time for #test-ship #torpedo 1 by 30)
	  (find undamaged #torpedo for #test-ship into [[#torpedo 2 [1 8] 1 500]])

(test #find-torpedo-1)
	  (find #test-ship #torpedo 1 into [#torpedo 1 [1 8] 1 500])

(test #dont-find-torpedo-3)
	  ~(find #test-ship #torpedo 3 into $)

(test #arc-projector)
	  (#test-ship #projector 1 arc [360 #up])

(test #arc-tractor)
	  (#test-ship #tractor 1 arc [4 5])

(test #arc-mtd)
	  (#test-ship #mtd 1 arc #down)

(test #value-projector)
	  (#test-ship #projector 1 value 100)

(test #value-tractor)
	  (#test-ship #tractor 1 value 250)

(test #value-mtd)
	  (#test-ship #mtd 1 value 4)

(test #details-projector)
	  (#test-ship #projector 1 details 141)

(test #details-tractor)
	  (#test-ship #tractor 1 details 0)

(test #details-mtd)
	  (#test-ship #mtd 1 details 0)

(test #repair-time-projector)
      (#test-ship #projector 1 repair time 0)

(test #repair-time-tractor)
      (#test-ship #tractor 1 repair time 800)

(test #repair-time-mtd)
      (#test-ship #mtd 1 repair time 16383)

(test #repair-time-type-not-found)
	  ~(#test-ship #missile 1 repair time $)

(test #repair-time-id-not-found)
	  ~(#test-ship #projector 2 repair time $)

(test #set-repair-time-projector)
      (set repair time for #test-ship #projector 1 to 300)

(test #set-repair-time-type-not-found)
      ~(set repair time for #test-ship #missile 1 to 300)

(test #set-repair-time-id-not-found)
      ~(set repair time for #test-ship #projector 2 to 300)

(test #increase-repair-time-tractor)
	  (#test-ship systems $Before)
	  (length of $Before into $LenBefore)
	  (increase repair time for #test-ship #tractor 1 by 200)
	  (#test-ship #tractor 1 repair time 1000)
	  (#test-ship systems $After)
	  (length of $After into $LenAfter)
	  (assert $LenBefore = $LenAfter)

(test #increase-repair-time-mtd)
	  (increase repair time for #test-ship #mtd 1 by 200)
	  (#test-ship #mtd 1 repair time 16383)

(test #decrease-repair-time-tractor)
	  (#test-ship systems $Before)
	  (length of $Before into $LenBefore)
	  (decrease repair time for #test-ship #tractor 1 by 200)
	  (#test-ship #tractor 1 repair time 600)
	  (#test-ship systems $After)
	  (length of $After into $LenAfter)
	  (assert $LenBefore = $LenAfter)

(test #decrease-repair-time-beyond-zero)
	  (decrease repair time for #test-ship #tractor 1 by 900)
	  (#test-ship #tractor 1 repair time 0)

(test #decrease-repair-time-mtd)
	  ~(decrease repair time for #test-ship #mtd 1 by 900)

(test #repair-tractor)
	  (repair #test-ship #tractor 1)
	  (#test-ship #tractor 1 repair time 0)

(test #destroy-ship)
	  (destroy #test-ship)
	  (#test-ship is destroyed)

(test #test-ship-is-not-destroyed)
	  ~(#test-ship is destroyed)

(test #test-ship-is-union)
	  (#test-ship fleet #union)

(test #closest-target-is-quellan)
	  (#closest-target fleet #quellan)

(test #near-target-is-quellan)
	  (#near-target fleet #quellan)

(test #far-target-is-quellan)
	  (#far-target fleet #quellan)

(test #distant-target-is-quellan)
	  (#distant-target fleet #quellan)

(test #closest-target-is-hostile)
	  (#test-ship considers #closest-target hostile)

(test #near-target-is-hostile)
	  (#test-ship considers #near-target hostile)

(test #far-target-is-hostile)
	  (#test-ship considers #far-target hostile)

(test #distant-target-is-hostile)
	  (#test-ship considers #distant-target hostile)

(test #closest-target-finds-test-ship-hostile)
	  (#closest-target considers #test-ship hostile)

(test #closest-target-finds-near-target-friendly)
	  (#closest-target considers #near-target friendly)

(test #closest-target-finds-far-target-friendly)
	  (#closest-target considers #far-target friendly)

(test #closest-target-finds-distant-target-friendly)
	  (#closest-target considers #distant-target friendly)

(test #closest-target-in-sensor-range)
	(#closest-target is in sensor range of #test-ship)

(test #near-target-in-sensor-range)
	(#near-target is in sensor range of #test-ship)

(test #far-target-in-sensor-range)
	(#far-target is in sensor range of #test-ship)

(test #distant-target-not-in-sensor-range)
	~(#distant-target is in sensor range of #test-ship)

(test #non-grid-object-not-in-sensor-range)
	~(#non-grid-object is in sensor range of #test-ship)

(test #asteroid-in-sensor-range)
	(#asteroid is in sensor range of #test-ship)

(test #closest-target-in-weapons-range)
	(#closest-target is in weapons range of #test-ship)

(test #near-target-in-weapons-range)
	(#near-target is in weapons range of #test-ship)

(test #far-target-not-in-weapons-range)
	~(#far-target is in weapons range of #test-ship)

(test #distant-target-not-in-weapons-range)
	~(#distant-target is in weapons range of #test-ship)

(test #non-grid-object-not-in-weapons-range)
	~(#non-grid-object is in weapons range of #test-ship)

(test #asteroid-in-weapons-range)
	(#asteroid is in weapons range of #test-ship)

(test #closest-target-in-matter-transmission-range)
	(move #closest-target to 3 4 5 5)
	(#closest-target is in matter transmission range of #test-ship)

(test #near-target-not-in-matter-transmission-range)
	~(#near-target is in matter transmission range of #test-ship)

(test #far-target-not-in-matter-transmission-range)
	~(#far-target is in matter transmission range of #test-ship)

(test #distant-target-not-in-matter-transmission-range)
	~(#distant-target is in matter transmission range of #test-ship)

(test #non-grid-object-not-in-matter-transmission-range)
	~(#non-grid-object is in matter transmission range of #test-ship)

(test #closest-in-sensor-range-of-near)
      (#closest-target is in sensor range of #near-target)

(test #closest-in-weapons-range-of-near)
      (#closest-target is in weapons range of #near-target)

(test #near-out-of-range-of-far)
      ~(#near-target is in weapons range of #far-target)

(test #near-out-of-range-of-distant)
      ~(#near-target is in sensor range of #distant-target)
