%% dgdebug -u schema-tests.dg schema.dg grid.dg utils.dg unit.dg stdlib.dg

(interface (code $))

(interface (ship type $))

(interface (stellar object $))

(reset randomness)

(global variable (list of lists [
	[1 2 3 4 5]
	[2 2 4 5 6]
	[3 2 4 5 6]
	[3 2 4 6 7]
	[4 1 7 8 9]]))

%% ----------------------------------------------------------------------------

#class
(test *)
(run *)	  (#test-ship class #cygnus-class)

#initialize
(test *)
(run *)
	  (initialize #test-ship as #cygnus-class)
	  (#test-ship class #cygnus-class)
	  (#test-ship energy 1000)
	  (#test-ship crystals 4)

#speed
(test *)
(run *)	  (#test-ship speed 400)

#warp-gradient
(test *)
(run *)	  (#test-ship warp gradient 4)

#energy
(test *)
(run *)	  (#test-ship energy 932)

#crystals
(test *)
(run *)	  (#test-ship crystals 4)

#decrease-energy
(test *)
(run *)
	  (decrease energy for #test-ship by 32)
	  (#test-ship energy 900)

#decrease-energy-below-zero
(test *)
(run *)	  ~(decrease energy for #test-ship by 1001)

#regenerate
(test *)
(run *)
	  (regenerate energy for #test-ship)
	  (#test-ship energy 972)

#regenerate-above-max
(test *)
(run *)
	  (regenerate energy for #test-ship)
	  (regenerate energy for #test-ship)
	  (#test-ship energy 1000)

#systems-list
(test *)
(run *)
	  (#test-ship systems $List)
	  (length of $List into 2)

#class-systems-list
(test *)
(run *)
	  (#test-ship class systems $List)
	  (length of $List into 24)

#undamaged-systems
(test *)
(run *)
	  (#test-ship undamaged systems $List)
	  (length of $List into 22)

#find-torpedoes
(test *)
(run *)
	  (find undamaged #torpedo for #test-ship into $Torps)
	  (assert $Torps = [[#torpedo 1 [1 8] 1 500]
	  		  		    [#torpedo 2 [1 8] 1 500]])

#dont-find-damaged-tractor
(test *)
(run *)	  (find undamaged #tractor for #test-ship into [])

#find-torpedo-1
(test *)
(run *)	  (find #test-ship #torpedo 1 into [#torpedo 1 [1 8] 1 500])

#dont-find-torpedo-3
(test *)
(run *)	  ~(find #test-ship #torpedo 3 into $)

#value-projector
(test *)
(run *)	  (#test-ship #projector 1 value 100)

#value-tractor
(test *)
(run *)	  (#test-ship #tractor 1 value 250)

#value-mtd
(test *)
(run *)	  (#test-ship #mtd 1 value 4)

#details-projector
(test *)
(run *)	  (#test-ship #projector 1 details 141)

#details-tractor
(test *)
(run *)	  (#test-ship #tractor 1 details 0)

#details-mtd
(test *)
(run *)	  (#test-ship #mtd 1 details 0)

#repair-time-projector
(test *)
(run *)      (#test-ship #projector 1 repair time 0)

#repair-time-tractor
(test *)
(run *)      (#test-ship #tractor 1 repair time 800)

#repair-time-mtd
(test *)
(run *)      (#test-ship #mtd 1 repair time 16383)

#repair-time-type-not-found
(test *)
(run *)	  ~(#test-ship #missile 1 repair time $)

#repair-time-id-not-found
(test *)
(run *)	  ~(#test-ship #projector 2 repair time $)

#set-repair-time-projector
(test *)
(run *)      (set repair time for #test-ship #projector 1 to 300)

#set-repair-time-type-not-found
(test *)
(run *)      ~(set repair time for #test-ship #missile 1 to 300)

#set-repair-time-id-not-found
(test *)
(run *)      ~(set repair time for #test-ship #projector 2 to 300)

#remove-1-2
(test *)
(run *)
	  (list of lists $List)
	  (remove 1 2 from $List into $NewList)
	  (assert $NewList = [
		[2 2 4 5 6]
		[3 2 4 5 6]
		[3 2 4 6 7]
		[4 1 7 8 9]])

#remove-1-2-twice
(test *)
(run *)
	  (list of lists $List)
	  (remove 1 2 from $List into $NewList)
	  (remove 1 2 from $NewList into $NewerList)
	  (assert $NewerList = [
		[2 2 4 5 6]
		[3 2 4 5 6]
		[3 2 4 6 7]
		[4 1 7 8 9]])

#remove-2-2
(test *)
(run *)
	  (list of lists $List)
	  (remove 2 2 from $List into $NewList)
	  (assert $NewList = [
	  	[1 2 3 4 5]
		[3 2 4 5 6]
		[3 2 4 6 7]
		[4 1 7 8 9]])

#remove-3-2
(test *)
(run *)
	  (list of lists $List)
	  (remove 3 2 from $List into $NewList)
	  (assert $NewList = [
	  	[1 2 3 4 5]
		[2 2 4 5 6]
		[3 2 4 6 7]
		[4 1 7 8 9]])

#remove-3-2-twice
(test *)
(run *)
	  (list of lists $List)
	  (remove 3 2 from $List into $NewList)
	  (remove 3 2 from $NewList into $NewerList)
	  (assert $NewerList = [
	  	[1 2 3 4 5]
		[2 2 4 5 6]
		[4 1 7 8 9]])

#remove-4-1
(test *)
(run *)
	  (list of lists $List)
	  (remove 4 1 from $List into $NewList)
	  (assert $NewList = [
	  	[1 2 3 4 5]
		[2 2 4 5 6]
		[3 2 4 5 6]
		[3 2 4 6 7]])

#remove-7-7
(test *)
(run *)
	  (list of lists $List)
	  (remove 7 7 from $List into $List)

#remove-in-filter
(test *)
(run *)
	  (list of lists $List)
	  (remove from $List found in [[1 2] [4 1]] into [
		[2 2 4 5 6]
		[3 2 4 5 6]
		[3 2 4 6 7]])

#remove-multiple-match
(test *)
(run *)
	  (list of lists $List)
	  (remove from $List found in [[3 2] [4 1]] into [
		[1 2 3 4 5]
		[2 2 4 5 6]])

#remove-in-empty-filter
(test *)
(run *)
	  (list of lists $List)
	  (remove from $List found in [] into $List)

#remove-empty-list-in-filter
(test *)
(run *)
	  (remove from [] found in [[1 2] [4 1]] into [])

#remove-in-disjoint-filter
(test *)
(run *)
	  (list of lists $List)
	  (remove from $List found in [[7 8] [9 9]] into $List)

#find-type-and-id
(test *)
(run *)
	  (list of lists $List)
	  (find 2 2 in $List into [2 2 4 5 6])

#dont-find-type-and-id
(test *)
(run *)
	  (list of lists $List)
	  ~(find 9 9 in $List into $)
