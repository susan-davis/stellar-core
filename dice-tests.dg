%% dgdebug -u dice-tests.dg dice.dg unit.dg stdlib.dg

(list of tests [
	  #d3
	  #one-roll
	  #wrap-around-1d6
	  #three-roll-individual
	  #two-roll-total
	  #two-roll-individual
	  #die-times-die
	  #three-roll-total
	  #wrap-around-3d6
	  #mix-one-and-three
	  #d36
	  #d216
	  #randomize-position
	  #reset-randomness
	  ])

%%-----------------------------------------------------------------------------

(set up $) (reset randomness)

%%-----------------------------------------------------------------------------

(test #d3)
	(d3 3)
	(d3 1)
	(d3 3)
	(d3 3)
	(d3 3)
	(d3 3)

(test #one-roll)
	(1d6 6)
	(1d6 1)
	(1d6 6)
	(1d6 6)
	(1d6 6)
	(1d6 5)

(test #wrap-around-1d6)
 	(now) (random list position 215)
	(1d6 3)
	(1d6 2)
	(1d6 6)
	(1d6 1)
	(1d6 6)

(test #three-roll-individual)
	(3d6 4 5 6)
	(3d6 4 3 1)
	(3d6 5 3 6)
	(3d6 6 5 6)
	(3d6 1 4 6)
	(3d6 5 1 5)

(test #two-roll-total)
	(2d6 11)
	(2d6 4)
	(2d6 9)
	(2d6 11)
	(2d6 10)
	(2d6 6)

(test #two-roll-individual)
    (2d6 5 6)
	(2d6 3 1)
	(2d6 3 6)
	(2d6 5 6)
	(2d6 4 6)
	(2d6 1 5)

(test #die-times-die)
    (d6 times d6 30)
	(d6 times d6 3)
	(d6 times d6 18)
	(d6 times d6 30)
	(d6 times d6 24)
	(d6 times d6 5)

(test #three-roll-total)
	(3d6 15)
	(3d6 8)
	(3d6 14)
	(3d6 17)
	(3d6 11)
	(3d6 11)

(test #wrap-around-3d6)
	(now) (random list position 215)
	(3d6 2 2 3)
	(3d6 6 1 2)
	(3d6 4 5 6)
	(3d6 4 3 1)
	(3d6 5 3 6)
	(3d6 6 5 6)
	(3d6 1 4 6)
	(3d6 5 1 5)

(test #mix-one-and-three)
	(1d6 6)
	(3d6 4 3 1)
	(1d6 6)
	(1d6 6)
	(3d6 1 4 6)
	(1d6 5)
	(1d6 6)
	(1d6 4)
	(3d6 4 5 1)

(test #d36)
    (d36 30)
	(d36 13)
	(d36 18)
	(d36 30)
	(d36 24)
	(d36 5)

(test #d216)
	(d216 138)
	(d216 121)
	(d216 162)
	(d216 210)
	(d216 24)
	(d216 149)

(test #randomize-position)
	(shuffle randomness)
	(random list position $Pos)
	(assert $Pos > 0)
	(assert $Pos < 217)
	$Pos

(test #reset-randomness)
	(3d6 4 5 6)
	(3d6 4 3 1)
	(3d6 5 3 6)
	(reset randomness)
	(3d6 4 5 6)
	(3d6 4 3 1)
	(3d6 5 3 6)
