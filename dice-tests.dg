(test #d20-with-advantage)
	(d20 19 with advantage)
	(d20 16 with advantage)
	(d20 12 with advantage)
	(d20 13 with advantage)

(test #d20-with-disadvantage)
	(d20 13 with disadvantage)
	(d20 15 with disadvantage)
	(d20 9 with disadvantage)
	(d20 4 with disadvantage)

(test #1dF)
	(1dF #up   1)
	(1dF #down 1)
	(1dF #up   1)
	(1dF #up   1)
	(1dF #up   1)
	(1dF #up   1)

(test #2dF)
	(2dF #up   1)
	(2dF 0     0)
	(2dF #up   1)
	(2dF #up   2)
	(2dF #down 1)
	(2dF 0     0)

(test #4dF)
	(4dF #up   1)
	(4dF #up   3)
	(4dF #down 1)
	(4dF #up   2)
	(4dF #down 1)
	(4dF #up   1)

(test #4d-attack-roll-with-spite)
	(roll 4 dice 16 1)
	(roll 4 dice 20 2)
	(roll 4 dice 16 1)
	(roll 4 dice 19 2)

(test #5d-attack-roll-with-spite)
	(roll 5 dice 22 1)
	(roll 5 dice 25 2)
	(roll 5 dice 17 1)
	(roll 5 dice 24 3)

(test #6d-attack-roll-with-spite)
	(roll 6 dice 23 1)
	(roll 6 dice 31 3)
	(roll 6 dice 22 1)
	(roll 6 dice 28 3)

(test #7-die-pool-against-target)
	(roll 7 dice with target 5 into 3)
	(roll 7 dice with target 5 into 5)
	(roll 7 dice with target 5 into 3)
	(roll 7 dice with target 5 into 3)
	(roll 7 dice with target 5 into 1)

(test #8-die-pool-against-target)
	(roll 8 dice with target 5 into 3)
	(roll 8 dice with target 5 into 5)
	(roll 8 dice with target 5 into 4)
	(roll 8 dice with target 5 into 2)
	(roll 8 dice with target 5 into 1)

(test #9-die-pool-against-target)
	(roll 9 dice with target 5 into 4)
	(roll 9 dice with target 5 into 6)
	(roll 9 dice with target 5 into 4)
	(roll 9 dice with target 5 into 3)
	(roll 9 dice with target 5 into 1)
