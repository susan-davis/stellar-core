%% dgdebug -u dice-tests.dg dice.dg unit.dg stdlib.dg

(list of tests [
	  #randomize-position
	  #reset-randomness
	  #1d3
	  #one-roll
	  #1d6-plus-3
	  #1d6-minus-3
	  #wrap-around-1d6
	  #two-roll-individual
	  #two-roll-total
	  #three-roll-individual
	  #three-roll-total
	  #wrap-around-3d6
	  #mix-one-and-three
	  #2d10-total
	  #2d10-individual
	  #d36
	  #d100
	  #d216
	  #1d10
	  #d20
	  #2d3-individual
	  #2d3-total
	  #d4
	  #2d6-daro
	  #3d6-taro
	  #d6xd6
	  #d6xd6-bonus
	  #d6xd6-penalty
	  #min-mid-max
	  #mixed-min-mid-max
	  #d8
	  #d12
	  #d20-with-advantage
	  #d20-with-disadvantage
	  #1dF
	  #2dF
	  #1-plus-2dF
	  #4dF
	  #2-plus-4dF
	  #4d-attack-roll-with-spite
	  #5d-attack-roll-with-spite
	  #6d-attack-roll-with-spite
	  #7-die-pool-against-target
	  #8-die-pool-against-target
	  #9-die-pool-against-target
	  #percent-of-zero
	  #percent-of-one
	  #percent-of-two
	  #percent-of-five
	  #percent-of-14
	  #percent-of-75
	  #percent-of-150
	  #percent-of-924
	  #percent-of-16234
	  ])

%%-----------------------------------------------------------------------------

(set up $) (reset randomness)

%%-----------------------------------------------------------------------------

(test #1d3)
	(roll #d3 3)
	(roll #d3 1)
	(roll #d3 3)
	(roll #d3 3)
	(roll #d3 3)

(test #one-roll)
	(roll #d6 6)
	(roll #d6 1)
	(roll #d6 6)
	(roll #d6 6)
	(roll #d6 6)
	(roll #d6 5)
	~(3d6 has rolled over)

(test #1d6-plus-3)
	(roll #d6 plus 3 9)
	(roll #d6 plus 3 4)
	(roll #d6 plus 3 9)
	(roll #d6 plus 3 9)
	(roll #d6 plus 3 9)
	(roll #d6 plus 3 8)

(test #1d6-minus-3)
	(roll #d6 minus 3 3)
	(roll #d6 minus 3 0)
	(roll #d6 minus 3 3)
	(roll #d6 minus 3 3)
	(roll #d6 minus 3 3)
	(roll #d6 minus 3 2)

(test #wrap-around-1d6)
 	(now) (3d6 list position 215)
	(roll #d6 3)
	(roll #d6 2)
	(roll #d6 6)
	(roll #d6 1)
	(roll #d6 6)
	(3d6 has rolled over)

(test #two-roll-individual)
	(roll 2 #d6 9)
	(roll 2 #d6 7)
	(roll 2 #d6 8)
	(roll 2 #d6 11)
	(roll 2 #d6 5)
	(roll 2 #d6 6)

(test #two-roll-total)
	(roll two #d6 4 5)
	(roll two #d6 4 3)
	(roll two #d6 5 3)
	(roll two #d6 6 5)
	(roll two #d6 1 4)
	(roll two #d6 5 1)

(test #three-roll-individual)
	(roll three #d6 4 5 6)
	(roll three #d6 4 3 1)
	(roll three #d6 5 3 6)
	(roll three #d6 6 5 6)
	(roll three #d6 1 4 6)
	(roll three #d6 5 1 5)

(test #three-roll-total)
	(roll 3 #d6 15)
	(roll 3 #d6 8)
	(roll 3 #d6 14)
	(roll 3 #d6 17)
	(roll 3 #d6 11)
	(roll 3 #d6 11)

(test #wrap-around-3d6)
	(now) (3d6 list position 215)
	(roll three #d6 2 2 3)
	(roll three #d6 6 1 2)
	(roll three #d6 4 5 6)
	(roll three #d6 4 3 1)
	(roll three #d6 5 3 6)
	(roll three #d6 6 5 6)
	(roll three #d6 1 4 6)
	(roll three #d6 5 1 5)
	(3d6 has rolled over)

(test #mix-one-and-three)
	(roll #d6 6)
	(roll three #d6 4 3 1)
	(roll #d6 6)
	(roll #d6 6)
	(roll three #d6 1 4 6)
	(roll #d6 5)
	(roll #d6 6)
	(roll #d6 4)
	(roll three #d6 4 5 1)

(test #d36)
    (roll #d36 30)
	(roll #d36 13)
	(roll #d36 18)
	(roll #d36 30)
	(roll #d36 24)
	(roll #d36 5)

(test #d216)
	(roll #d216 138)
	(roll #d216 121)
	(roll #d216 162)
	(roll #d216 210)
	(roll #d216 24)
	(roll #d216 149)

(test #2d10-individual)
	(roll two #d10 6 9)
	(roll two #d10 6 1)
	(roll two #d10 8 1)
	(roll two #d10 1 2)
	(roll two #d10 7 5)
	(roll two #d10 5 4)
	(roll two #d10 9 8)

(test #2d10-total)
	(roll 2 #d10 15)
	(roll 2 #d10 7)
	(roll 2 #d10 9)
	(roll 2 #d10 3)
	(roll 2 #d10 12)
	(roll 2 #d10 9)
	(roll 2 #d10 17)

(test #d100)
	(roll #d100 69)
	(roll #d100 61)
	(roll #d100 81)
	(roll #d100 12)
	(roll #d100 75)
	(roll #d100 54)
	(roll #d100 98)

(test #1d10)
	(roll #d10 9)
	(roll #d10 3)
	(roll #d10 6)
	(roll #d10 5)
	(roll #d10 9)
	(roll #d10 2)
	(roll #d10 4)
	(roll #d10 3)

(test #d20)
	(roll #d20 19)
	(roll #d20 13)
	(roll #d20 16)
	(roll #d20 15)
	(roll #d20 9)
	(roll #d20 12)
	(roll #d20 4)
	(roll #d20 13)

(test #randomize-position)
	(shuffle randomness)
	(3d6 list position $Pos)
	(assert $Pos > 0)
	(assert $Pos < 217)
	(assert $Pos > 0)
	(assert $Pos < 217)
	$Pos

(test #reset-randomness)
	(roll three #d6 4 5 6)
	(roll three #d6 4 3 1)
	(roll three #d6 5 3 6)
	(reset randomness)
	(roll three #d6 4 5 6)
	(roll three #d6 4 3 1)
	(roll three #d6 5 3 6)

(test #2d3-individual)
	(roll two #d3 2 3)
	(roll two #d3 2 2)
	(roll two #d3 3 2)
	(roll two #d3 3 3)
	(roll two #d3 1 2)
	(roll two #d3 3 1)

(test #2d3-total)
	(roll 2 #d3 5)
	(roll 2 #d3 4)
	(roll 2 #d3 5)
	(roll 2 #d3 6)
	(roll 2 #d3 3)
	(roll 2 #d3 4)

(test #d4)
	(roll #d4 4)
	(roll #d4 3)
	(roll #d4 4)
	(roll #d4 3)
	(roll #d4 2)
	(roll #d4 3)

(test #2d6-daro)
	(now) (3d6 list position 9)
	(roll two #d6 9 DARO)
	(roll two #d6 18 DARO)
	(3d6 list position 13)
	(roll two #d6 5 DARO)
	(now) (3d6 list position 17)
	(roll two #d6 5 DARO)
	(3d6 list position 19)

(test #3d6-taro)
	(now) (3d6 list position 9)
	(roll three #d6 10 TARO)
	(roll three #d6 14 TARO)
	(roll three #d6 11 TARO)
	(3d6 list position 13)

(test #d6xd6)
	(roll #d6 times #d6 20)
	(roll #d6 times #d6 12)
	(roll #d6 times #d6 15)
	(roll #d6 times #d6 30)
	(roll #d6 times #d6 4)
	(roll #d6 times #d6 5)
	(roll #d6 times #d6 18)

(test #d6xd6-bonus)
	(roll #d6 times #d6 adding 2 18)
	(roll #d6 times #d6 adding 2 48)
	(roll #d6 times #d6 adding 2 42)
	(roll #d6 times #d6 adding 2 36)
	(roll #d6 times #d6 adding 2 3)

(test #d6xd6-penalty)
	(roll #d6 times #d6 subtracting 2 6)
	(roll #d6 times #d6 subtracting 2 24)
	(roll #d6 times #d6 subtracting 2 18)
	(roll #d6 times #d6 subtracting 2 12)
	(roll #d6 times #d6 subtracting 2 1)

(test #min-mid-max)
	(roll #d6 min mid max 4 5 6)
	(roll #d6 min mid max 1 3 4)
	(roll #d6 min mid max 3 5 6)
	(roll #d6 min mid max 5 6 6)
	(roll #d6 min mid max 1 4 6)
	(roll #d6 min mid max 1 5 5)

(test #mixed-min-mid-max)
	(roll #d10 #d6 #d8 min mid max 3 6 9)
	(roll #d6 #d10 #d8 min mid max 1 5 6)
	(roll #d10 #d6 #d8 min mid max 2 6 9)
	(roll #d10 #d6 #d8 min mid max 3 4 6)
	(roll #d10 #d6 #d8 min mid max 1 2 6)
	(roll #d10 #d6 #d8 min mid max 4 5 8)

(test #d8)
	(roll #d8 3)
	(roll #d8 6)
	(roll #d8 5)
	(roll #d8 2)
	(roll #d8 4)
	(roll #d8 3)

(test #d12)
    (roll #d12 10)
	(roll #d12 5)
	(roll #d12 6)
	(roll #d12 10)
	(roll #d12 8)
	(roll #d12 2)

(test #d20-with-advantage)
	(roll #d20 19 with advantage)
	(roll #d20 16 with advantage)
	(roll #d20 12 with advantage)
	(roll #d20 13 with advantage)
	(roll #d20 11 with advantage)

(test #d20-with-disadvantage)
	(roll #d20 13 with disadvantage)
	(roll #d20 15 with disadvantage)
	(roll #d20 9 with disadvantage)
	(roll #d20 4 with disadvantage)
	(roll #d20 2 with disadvantage)

(test #1dF)
	(roll 1dF #up   1)
	(roll 1dF #down 1)
	(roll 1dF #up   1)
	(roll 1dF #up   1)
	(roll 1dF #up   1)
	(roll 1dF #up   1)

(test #2dF)
	(roll 2dF #up   1)
	(roll 2dF 0     0)
	(roll 2dF #up   1)
	(roll 2dF #up   2)
	(roll 2dF #down 1)
	(roll 2dF 0     0)
	(roll 2dF #up   1)
	(roll 2dF #up   1)

(test #1-plus-2dF)
	(1 plus 2dF 2)
	(1 plus 2dF 1)
	(1 plus 2dF 2)
	(1 plus 2dF 3)
	(1 plus 2dF 0)

(test #4dF)
	(roll 4dF #up   1)
	(roll 4dF #up   3)
	(roll 4dF #down 1)
	(roll 4dF #up   2)
	(roll 4dF #down 1)
	(roll 4dF #up   1)

(test #2-plus-4dF)
	(2 plus 4dF 3)
	(2 plus 4dF 5)
	(2 plus 4dF 1)
	(2 plus 4dF 4)
	(2 plus 4dF 1)
	(2 plus 4dF 3)

(test #4d-attack-roll-with-spite)
	(roll 4 #d6 16 with 1 spite)
	(roll 4 #d6 20 with 0 spite)
	(roll 4 #d6 16 with 1 spite)
	(roll 4 #d6 19 with 0 spite)

(test #5d-attack-roll-with-spite)
	(roll 5 #d6 22 with 0 spite)
	(roll 5 #d6 25 with 0 spite)
	(roll 5 #d6 17 with 2 spite)
	(roll 5 #d6 24 with 0 spite)

(test #6d-attack-roll-with-spite)
	(roll 6 #d6 23 with 1 spite)
	(roll 6 #d6 31 with 0 spite)
	(roll 6 #d6 22 with 2 spite)
	(roll 6 #d6 28 with 0 spite)

(test #7-die-pool-against-target)
	(roll 7 #d6 with target 5 into 3)
	(roll 7 #d6 with target 5 into 5)
	(roll 7 #d6 with target 5 into 3)
	(roll 7 #d6 with target 5 into 3)
	(roll 7 #d6 with target 5 into 1)

(test #8-die-pool-against-target)
	(roll 8 #d6 with target 5 into 3)
	(roll 8 #d6 with target 5 into 5)
	(roll 8 #d6 with target 5 into 4)
	(roll 8 #d6 with target 5 into 2)
	(roll 8 #d6 with target 5 into 1)

(test #9-die-pool-against-target)
	(roll 9 #d6 with target 5 into 4)
	(roll 9 #d6 with target 5 into 6)
	(roll 9 #d6 with target 5 into 4)
	(roll 9 #d6 with target 5 into 3)
	(roll 9 #d6 with target 5 into 1)

(test #percent-of-zero)
	(percentage of 0 into 0)

(test #percent-of-one)
	(percentage of 1 into 1)

(test #percent-of-two)
	(percentage of 2 into 2)
	(percentage of 2 into 1)
	(percentage of 2 into 2)
	(percentage of 2 into 1)

(test #percent-of-five)
	(percentage of 5 into 1)
	(percentage of 5 into 5)
	(percentage of 5 into 4)
	(percentage of 5 into 1)

(test #percent-of-14)
	(percentage of 14 into 13)
	(percentage of 14 into 9)
	(percentage of 14 into 12)
	(percentage of 14 into 4)

(test #percent-of-75)
	(percentage of 75 into 69)
	(percentage of 75 into 61)
	(percentage of 75 into 12)
	(percentage of 75 into 75)

(test #percent-of-150)
	(percentage of 150 into 138)
	(percentage of 150 into 121)
	(percentage of 150 into 24)
	(percentage of 150 into 149)

(test #percent-of-924)
	(percentage of 924 into 593)
	(percentage of 924 into 656)
	(percentage of 924 into 632)
	(percentage of 924 into 829)

(test #percent-of-16234)
	(percentage of 16234 into 10363)
	(percentage of 16234 into 12180)
	(percentage of 16234 into 1805)
	(percentage of 16234 into 8116)
