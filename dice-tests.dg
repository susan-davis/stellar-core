%% dgdebug -u dice-tests.dg dice.dg unit.dg stdlib.dg

(list of tests [
	  #randomize-position
	  #reset-randomness
	  #1d3
	  #one-roll
	  #wrap-around-1d6
	  #two-roll-individual
	  #two-roll-total
	  #three-roll-individual
	  #three-roll-total
	  #wrap-around-3d6
	  #mix-one-and-three
	  #2d10-total
	  #2d10-individual
	  #d36
	  #d100
	  #d216
	  #1d10
	  #d20
	  #2d3-individual
	  #2d3-total
	  #d4
	  #2d6-daro
	  #3d6-taro
	  #d6xd6
	  #min-mid-max
	  #d8
	  #d12
	  #d20-with-advantage
	  #d20-with-disadvantage
	  #1dF
	  #2dF
	  #4dF
	  #4d-attack-roll-with-spite
	  #5d-attack-roll-with-spite
	  #6d-attack-roll-with-spite
	  #7-die-pool-against-target
	  #8-die-pool-against-target
	  #9-die-pool-against-target
	  ])

%%-----------------------------------------------------------------------------

(set up $) (reset randomness)

%%-----------------------------------------------------------------------------

(test #1d3)
	(1d3 3)
	(1d3 1)
	(1d3 3)
	(1d3 3)
	(1d3 3)

(test #one-roll)
	(1d6 6)
	(1d6 1)
	(1d6 6)
	(1d6 6)
	(1d6 6)
	(1d6 5)

(test #wrap-around-1d6)
 	(now) (3d6 list position 215)
	(1d6 3)
	(1d6 2)
	(1d6 6)
	(1d6 1)
	(1d6 6)

(test #two-roll-individual)
	(2d6 9)
	(2d6 7)
	(2d6 8)
	(2d6 11)
