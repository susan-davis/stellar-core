%% dgdebug -u dice-tests.dg dice.dg unit.dg stdlib.dg

(list of tests [
	  #randomize-position
	  #reset-randomness
	  #1d3
	  #one-roll
	  #wrap-around-1d6
	  #two-roll-individual
	  #two-roll-total
	  #three-roll-individual
	  #three-roll-total
	  #wrap-around-3d6
	  #mix-one-and-three
	  #2d10-total
	  #2d10-individual
	  #d36
	  #d100
	  #d216
	  #1d10
	  #d20
	  ])

%%-----------------------------------------------------------------------------

(set up $) (reset randomness)

%%-----------------------------------------------------------------------------

(test #1d3)
	(1d3 3)
	(1d3 1)
	(1d3 3)
	(1d3 3)
	(1d3 3)

(test #one-roll)
	(1d6 6)
	(1d6 1)
	(1d6 6)
	(1d6 6)
	(1d6 6)
	(1d6 5)

(test #wrap-around-1d6)
 	(now) (3d6 list position 215)
	(1d6 3)
	(1d6 2)
	(1d6 6)
	(1d6 1)
	(1d6 6)

(test #two-roll-individual)
	(2d6 9)
	(2d6 7)
	(2d6 8)
	(2d6 11)
	(2d6 5)
	(2d6 6)

(test #two-roll-total)
	(2d6 4 5)
	(2d6 4 3)
	(2d6 5 3)
	(2d6 6 5)
	(2d6 1 4)
	(2d6 5 1)

(test #three-roll-individual)
	(3d6 4 5 6)
	(3d6 4 3 1)
	(3d6 5 3 6)
	(3d6 6 5 6)
	(3d6 1 4 6)
	(3d6 5 1 5)

(test #three-roll-total)
	(3d6 15)
	(3d6 8)
	(3d6 14)
	(3d6 17)
	(3d6 11)
	(3d6 11)

(test #wrap-around-3d6)
	(now) (3d6 list position 215)
	(3d6 2 2 3)
	(3d6 6 1 2)
	(3d6 4 5 6)
	(3d6 4 3 1)
	(3d6 5 3 6)
	(3d6 6 5 6)
	(3d6 1 4 6)
	(3d6 5 1 5)

(test #mix-one-and-three)
	(1d6 6)
	(3d6 4 3 1)
	(1d6 6)
	(1d6 6)
	(3d6 1 4 6)
	(1d6 5)
	(1d6 6)
	(1d6 4)
	(3d6 4 5 1)

(test #d36)
    (d36 30)
	(d36 13)
	(d36 18)
	(d36 30)
	(d36 24)
	(d36 5)

(test #d216)
	(d216 138)
	(d216 121)
	(d216 162)
	(d216 210)
	(d216 24)
	(d216 149)

(test #2d10-individual)
	(2d10 6 9)
	(2d10 6 1)
	(2d10 8 1)
	(2d10 1 2)
	(2d10 7 5)
	(2d10 5 4)
	(2d10 9 8)

(test #2d10-total)
	(2d10 15)
	(2d10 7)
	(2d10 9)
	(2d10 3)
	(2d10 12)
	(2d10 9)
	(2d10 17)

(test #d100)
	(d100 69)
	(d100 61)
	(d100 81)
	(d100 12)
	(d100 75)
	(d100 54)
	(d100 98)

(test #1d10)
	(1d10 9)
	(1d10 3)
	(1d10 6)
	(1d10 5)
	(1d10 9)
	(1d10 2)
	(1d10 4)

(test #d20)
	(d20 19)
	(d20 13)
	(d20 16)
	(d20 15)
	(d20 9)
	(d20 12)
	(d20 4)

(test #randomize-position)
	(shuffle randomness)
	(3d6 list position $Pos)
	(assert $Pos > 0)
	(assert $Pos < 217)
	(assert $Pos > 0)
	(assert $Pos < 217)
	$Pos

(test #reset-randomness)
	(3d6 4 5 6)
	(3d6 4 3 1)
	(3d6 5 3 6)
	(reset randomness)
	(3d6 4 5 6)
	(3d6 4 3 1)
	(3d6 5 3 6)
