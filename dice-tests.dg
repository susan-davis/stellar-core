(test #randomize-position)
	(shuffle randomness)
	(3d6 list position $Pos)
	(assert $Pos > 0)
	(assert $Pos < 217)
	(assert $Pos > 0)
	(assert $Pos < 217)
	$Pos

(test #reset-randomness)
	(3d6 4 5 6)
	(3d6 4 3 1)
	(3d6 5 3 6)
	(reset randomness)
	(3d6 4 5 6)
	(3d6 4 3 1)
	(3d6 5 3 6)

(test #2d3-individual)
	(2d3 2 3)
	(2d3 2 2)
	(2d3 3 2)
	(2d3 3 3)
	(2d3 1 2)
	(2d3 3 1)

(test #2d3-total)
	(2d3 5)
	(2d3 4)
	(2d3 5)
	(2d3 6)
	(2d3 3)
	(2d3 4)

(test #d4)
	(d4 4)
	(d4 2)
	(d4 2)
	(d4 4)
	(d4 3)
	(d4 1)

(test #2d6-daro)
	(now) (3d6 list position 9)
	(2d6 9 DARO)
	(2d6 18 DARO)
	(3d6 list position 13)
	(2d6 5 DARO)
	(now) (3d6 list position 17)
	(2d6 5 DARO)
	(3d6 list position 19)

(test #3d6-taro)
	(now) (3d6 list position 9)
	(3d6 10 TARO)
	(3d6 14 TARO)
	(3d6 11 TARO)
	(3d6 list position 13)

(test #d6xd6)
	(d6 times d6 20)
	(d6 times d6 12)
	(d6 times d6 15)
	(d6 times d6 30)
	(d6 times d6 4)
	(d6 times d6 5)
	(d6 times d6 18)

(test #min-mid-max)
	(min mid max 4 5 6)
	(min mid max 1 3 4)
	(min mid max 3 5 6)
	(min mid max 5 6 6)
	(min mid max 1 4 6)
	(min mid max 1 5 5)

(test #d8)
    (d8 8)
	(d8 4)
	(d8 5)
	(d8 8)
	(d8 6)
