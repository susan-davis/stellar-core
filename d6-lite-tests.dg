%% dgdebug -u d6-lite-tests.dg d6-lite.dg unit.dg stdlib.dg

(list of tests [
	#d3
	#d6
	#d36
	#d216
	#d1296
    ])

(set up $)	(reset randomness)

%%-----------------------------------------------------------------------------

($ 0 times with max $) %% do nothing

($Dice $N times with max $Max)
	(roll $Dice $Roll)
	($Roll > 0) ~($Roll > $Max)
	($N minus 1 into $NMinusOne)
	($Dice $NMinusOne times with max $Max)

#d3
(test *)
	(* 1000 times with max 3)

#d6
(test *)
	(* 1000 times with max 6)

#d36
(test *)
	(* 1000 times with max 36)

#d216
(test *)
	(* 1000 times with max 216)

#d1296
(test *)
	(* 1000 times with max 1296)
