#closest-unoccupied-square-near-target
(test *)
(run *)
	(#test-ship position $Here)
	(#near-target position $There)
	(closest unoccupied square to $There from $Here into $Unoccupied)
	(assert $Unoccupied = [315 425 0])

#closest-unoccupied-square-far-target
(test *)
(run *)
	(#test-ship position $Here)
	(#far-target position $There)
	(closest unoccupied square to $There from $Here into $Unoccupied)
	(assert $Unoccupied = [423 315 0])

