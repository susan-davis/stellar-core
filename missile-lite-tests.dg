%% dgdebug -u missile-lite-tests.dg test-ships.dg missile-lite.dg weapons.dg
%%            sensor.dg damage.dg arc.dg maneuver.dg schema.dg sector.dg
%%            grid.dg unit.dg stdlib.dg

(interface (ship type $))  %% silence warnings

(interface (code $))       %% silence warnings

%%-----------------------------------------------------------------------------

#launch-no-missiles
(test *)
(run *)
    (launch 0 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(#test-ship shields 500)
	(#test-ship energy 932)

#launch-missiles
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(#test-ship shields 104)
	(#test-ship energy 528)
	(#test-ship systems length 6)

#launch-more-missiles
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(#test-ship shields 104)
	(#test-ship energy 528)
	(#test-ship systems length 6)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(#test-ship is destroyed)

#missile-not-on-map
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	~(#missile is on the map)

#test-ship-point-defence
(test *)
(run *)
	(set autofire for #test-ship to [[#projector 1]])
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	%% one shot down, remaining 3 hit
	(#test-ship shields 203)
	(#test-ship energy 624)
	(#test-ship systems length 5)

#neutral-ship-point-defence
(test *)
(run *)
	(set autofire for #neutral-ship to [[#interceptor 1]])
	(launch 2 missiles of 499 2 200 from [5000 5000] at #neutral-ship)
	%% one shot down, remaining one hits
	(#neutral-ship energy 300)
