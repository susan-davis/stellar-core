%% dgdebug -u missile-lite-tests.dg test-ships.dg missile-lite.dg weapons.dg
%%            sensor.dg damage.dg arc.dg maneuver.dg schema.dg sector.dg
%%            grid.dg unit.dg stdlib.dg

(interface (ship type $))  %% silence warnings

(interface (code $))       %% silence warnings

%%-----------------------------------------------------------------------------

#launch-no-missiles
(test *)
(run *)
    (launch 0 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(#test-ship shields 500)
	(#test-ship energy 932)

#launch-missiles
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(#test-ship shields 104)
	(#test-ship energy 528)
	(#test-ship systems length 6)

#launch-more-missiles
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(#test-ship shields 104)
	(#test-ship energy 528)
	(#test-ship systems length 6)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(#test-ship is destroyed)

#missile-not-on-map
(test *)
(run *)
    (launch 1 missiles of 499 2 200 from [3544 4444] at #test-ship)
	~(#missile is on the map)

#no-missiles-in-flight
(test *)
(run *)
    (launch 1 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(number of missiles in flight 0)

#test-ship-point-defence
(test *)
(run *)
	(set autofire for #test-ship to [[#projector 1]])
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	%% one shot down, remaining 3 hit
	(#test-ship shields 203)
	(#test-ship energy 624)
	(#test-ship systems length 5)

#neutral-ship-point-defence
(test *)
(run *)
	(set autofire for #neutral-ship to [[#interceptor 1]])
	(launch 2 missiles of 499 2 200 from [5000 5000] at #neutral-ship)
	%% one shot down, remaining one hits
	(#neutral-ship energy 300)

#q7-point-defence-bow
(test *)
(run *)
	(use q7)
	(set autofire for #distant-target to
	    [[#projector 2] [#projector 3] [#projector 4] [#projector 5]])
    (launch 2 missiles of 1097 2 500 from [3444 4544] at #distant-target)
    (#distant-target shields 500)
	(#distant-target energy 2990)
	(#distant-target systems length 0)

#q7-point-defence-stern
(test *)
(run *)
    (use q7)
	(set autofire for #distant-target to
	    [[#projector 2] [#projector 3] [#projector 4] [#projector 5]])
	(turn #distant-target away from #test-ship)
    (launch 2 missiles of 1097 2 500 from [3444 4544] at #distant-target)
    (#distant-target shields 500)
	(#distant-target energy 2990)
	(#distant-target systems length 0)

#q7-autofire-all-around
(test *)
(run *)
    (use q7)
	(turn #distant-target away from #test-ship)
	(set autofire for #distant-target to
	    [[#projector 2] [#projector 3] [#projector 4] [#projector 5]])
    (launch 2 missiles of 1097 2 500 from [3444 4544] at #distant-target)
    (launch 2 missiles of 1097 2 500 from [3744 4544] at #distant-target)
    (launch 2 missiles of 1097 2 500 from [3544 4844] at #distant-target)
    (#distant-target shields 100)
	(#distant-target energy 2380)
	(#distant-target systems length 2)

#torpedoes-beyond-boost
(test *)
(run *)
    (use q7)
	(set autofire for #distant-target to
	    [[#projector 2] [#projector 3] [#projector 4] [#projector 5]])
    (drag #distant-target to position [3999 4999])
	(drag #test-ship to position [3000 4000])
	(turn #distant-target to face #test-ship)
	(turn #test-ship to face #distant-target)
	(#test-ship fires at #distant-target using 100 energy and 2 ammo)
	%% one missile shot down, one gets through
    (#distant-target shields 219)
	(#distant-target energy 2745)
	(#distant-target systems length 1)
