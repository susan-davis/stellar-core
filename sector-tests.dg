%% dgdebug -u sector-tests.dg sector.dg grid.dg unit.dg stdlib.dg

#test-ship
(grid object *)
(* initial position [3456 4567 315])

#closest-target
(grid object *)
(* initial position [3544 4444 0])

#near-target
(grid object *)
(* initial position [3144 4244 0])

#far-target
(grid object *)
(* initial position [4244 3144 0])

#distant-target
(grid object *)
(* initial position [1544 9844 0])

#non-grid-object
(* initial position [3744 4744 0])

#sun
(star *)
(* initial position [5774 5774 0])

#planet
(planet *)
(* initial position [5754 5754 0])

#other-planet
(planet *)
(* initial position [5734 5734 0])

(reset map)
	(now) ~(x increases west)
	(now) (y increases south)
	(now) (storing positions in units)
	(now) (map size 1170)
	(now) (map offset 100)

(set up $)
    (reset map)
	(exhaust) {
	    *(grid object $Object)
		($Object initial position $Position)
		(now) ($Object position $Position)
		(now) (y increases south)
	}

%%-----------------------------------------------------------------------------

#schema
(test *)
(run *)
    (#test-ship sector x 3)
    (#test-ship sector y 4)
    (#test-ship subsector x 5)
    (#test-ship subsector y 6)
	(#test-ship position x 6)
	(#test-ship position y 7)
	(#test-ship fine position x 56)
	(#test-ship fine position y 67)

#objects-in-sector
(test *)
(run *)	(objects in sector 3 4 into [#test-ship #closest-target #near-target])

#objects-in-empty-sector
(test *)
(run *)	(objects in sector 1 8 into [])

#object-at-ship-position
(test *)
(run *)
	(#test-ship initial position $Here)
	(object at $Here into #test-ship)

#object-next-to-ship-position
(test *)
(run *)	~(object at [3455 4555] into $)

#objects-in-ships-sector
(test *)
(run *) (objects in sector 3 4 into [#test-ship #closest-target #near-target])

#objects-in-ships-subsector
(test *)
(run *)	(objects in subsector 3 4 5 6 into [#test-ship])

#number-of-objects-in-ships-subsector
(test *)
(run *)	(number of objects in subsector 3 4 5 6 into 1)

#objects-at-ships-position
(test *)
(run *) (objects at position 3 4 5 6 6 7 into [#test-ship])

#objects-at-closest-target
(test *)
(run *)	(objects in subsector 3 4 6 5 into [#closest-target])

#object-at-near-target
(test *)
(run *)	(top object in subsector 3 4 2 3 into #near-target)

#top-object-at-far-target
(test *)
(run *)	(top object in subsector 4 3 3 2 into #far-target)

#objects-in-empty-subsector
(test *)
(run *)	(objects in subsector 8 8 10 10 into [])

#number-of-objects-in-empty-subsector
(test *)
(run *)	(number of objects in subsector 8 8 10 10 into 0)

#objects-in-star-system
(test *)
(run *)	(objects in subsector 5 5 8 8 into [#sun #planet #other-planet])

#number-of-objects-in-star-system
(test *)
(run *)	(number of objects in subsector 5 5 8 8 into 3)

#top-object-is-star
(test *)
(run *)	(top object in subsector 5 5 8 8 into #sun)

#split-position
(test *)
(run *) (split position [3444 4544] into 3 4 5 6 5 5)

#test-ship-sector
(test *)
(run *) (#test-ship is in sector 3 4)

#test-ship-wrong-sector
(test *)
(run *) ~(#test-ship is in sector 4 3)

#test-ship-subsector
(test *)
(run *) (#test-ship is in subsector 3 4 5 6)

#test-ship-wrong-subsector
(test *)
(run *) ~(#test-ship is in subsector 3 4 6 5)

#test-ship-position
(test *)
(run *) (#test-ship is at position 3 4 5 6 6 7)

#test-ship-wrong-position
(test *)
(run *) ~(#test-ship is at position 3 4 5 6 5 5)

#non-grid-object-no-sector
(test *)
(run *) ~(#non-grid-object is in sector 3 4)

#closest-target-same-sector
(test *)
(run *) (#test-ship is in the same sector as #closest-target)

#near-target-same-sector
(test *)
(run *) (#test-ship is within 0 sectors of #near-target)

#far-target-one-sector
(test *)
(run *) (#test-ship is within 1 sectors of #near-target)

#distant-target-five-sectors
(test *)
(run *) (#test-ship is within 5 sectors of #distant-target)

#non-grid-object-no-sectors
(test *)
(run *) ~(#non-grid-object is within 16383 sectors of #test-ship)

#closest-target-one-subsector
(test *)
(run *) (#test-ship is within 1 subsectors of #closest-target)

#near-target-three-subsectors
(test *)
(run *) (#test-ship is within 3 subsectors of #near-target)

#far-target-no-subsectors
(test *)
(run *) ~(#test-ship is within 16383 subsectors of #far-target)

#non-grid-object-no-subsectors
(test *)
(run *) ~(#non-grid-object is within 16383 subsectors of #test-ship)

#closest-target-in-subsector
(test *)
(run *)
    (move #test-ship to position [3555 4455])
	(#test-ship is in the same subsector as #closest-target)

#closest-target-two-positions-away
(test *)
(run *)
    (move #test-ship to position [3555 4465])
	(#test-ship is within 2 positions of #closest-target)

#closest-target-at-position
(test *)
(run *)
    (move #test-ship to position [3545 4446])
	(#test-ship is at the same position as #closest-target)

#closest-target-not-at-fine-position
(test *)
(run *)
    (move #test-ship to position [3545 4446])
	~(#test-ship is at precisely the same position as #closest-target)

#closest-target-two-millisectors-away
(test *)
(run *)
    (move #test-ship to position [3545 4446])
	(#test-ship is within 2 millisectors of #closest-target)

#closest-target-at-fine-position
(test *)
(run *)
    (move #test-ship to position [3544 4444])
	(#test-ship is at precisely the same position as #closest-target)

#no-gravity-deep-space
(test *)
(run *) ~(sector 3 4 is in a gravity well)

#flat-space-deep-space
(test *)
(run *) (sector 3 4 is in flat space)

#gravity-solar-system
(test *)
(run *) (sector 5 5 is in a gravity well)

#not-flat-solar-system
(test *)
(run *) ~(sector 5 5 is in flat space)

#massive-object-solar-system
(test *)
(run *) (sector 5 5 has a very massive object)

#gravity-inside-solar-system
(test *)
(run *) (subsector 5 5 5 5 is in a gravity well)

#not-flat-inside-solar-system
(test *)
(run *) ~(subsector 5 5 5 5 is in flat space)

#gravity-at-position-inside-solar-system
(test *)
(run *) (position 5 5 5 5 5 5 is in a gravity well)

#not-flat-at-position-inside-solar-system
(test *)
(run *) ~(position 5 5 5 5 5 5 is in flat space)

#deep-gravity-sun
(test *)
(run *) (subsector 5 5 8 8 is deep in a gravity well)

#not-flat-sun
(test *)
(run *) ~(subsector 5 5 8 8 is in flat space)

#deep-gravity-around-sun
(test *)
(run *) (position 5 5 8 8 5 5 is deep in a gravity well)

#not-flat-around-sun
(test *)
(run *) ~(position 5 5 8 8 5 5 is in flat space)

#steep-gravity-at-sun
(test *)
(run *) (position 5 5 8 8 8 8 is in a very steep gravity well)

#not-flat-at-sun
(test *)
(run *) ~(position 5 5 8 8 8 8 is in flat space)

#rogue-planet-has-gravity
(test *)
(run *)
    (move #other-planet to position [3456 4567])
	(subsector 3 4 5 6 is in a gravity well)

#rogue-planet-has-deep-gravity
(test *)
(run *)
    (move #other-planet to position [3456 4567])
	(position 3 4 5 6 6 7 is deep in a gravity well)

#rogue-planet-has-very-steep-gravity
(test *)
(run *)
    (move #other-planet to position [3456 4567])
    (#test-ship is in a very steep gravity well)

#off-the-planet-isnt-as-steep
(test *)
(run *)
    (move #other-planet to position [3457 4567])
    (#test-ship is deep in a gravity well)
%%    ~(#test-ship is in a very steep gravity well)

%% TODO: write tests for reintroduced integer predicates
