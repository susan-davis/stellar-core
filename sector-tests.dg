%% dgdebug -u sector-tests.dg sector.dg grid.dg unit.dg stdlib.dg

#test-ship
(grid object *)
(* initial position [3456 4567 315])

#closest-target
(grid object *)
(* initial position [3544 4444 0])

#near-target
(grid object *)
(* initial position [3144 4244 0])

#far-target
(grid object *)
(* initial position [4244 3144 0])

#distant-target
(grid object *)
(* initial position [1544 9844 0])

#non-grid-object
(* initial position [3744 4744 0])

#sun
(grid object *)
(* initial position [5774 5774 0])

#planet
(grid object *)
(* initial position [5754 5754 0])

#other-planet
(grid object *)
(* initial position [5734 5734 0])

(reset map)
	(now) ~(x increases west)
	(now) (y increases south)
	(now) (storing positions in units)
	(now) (map size 1170)
	(now) (map offset 100)

(set up $)
    (reset map)
	(exhaust) {
	    *(grid object $Object)
		($Object initial position $Position)
		(now) ($Object position $Position)
		(now) (y increases south)
	}

%%-----------------------------------------------------------------------------

#schema
(test *)
(run *)
    (#test-ship sector x 3)
    (#test-ship sector y 4)
    (#test-ship subsector x 5)
    (#test-ship subsector y 6)
	(#test-ship position x 6)
	(#test-ship position y 7)
	(#test-ship fine position x 56)
	(#test-ship fine position y 67)

#objects-in-sector
(test *)
(run *)	(objects in sector 3 4 into [#test-ship #closest-target #near-target])

#objects-in-empty-sector
(test *)
(run *)	(objects in sector 1 8 into [])

#object-at-ship-position
(test *)
(run *)
	(#test-ship initial position $Here)
	(object at $Here into #test-ship)

#object-next-to-ship-position
(test *)
(run *)	~(object at [3455 4555] into $)

#objects-in-ships-subsector
(test *)
(run *)	(objects in subsector 3 4 5 6 into [#test-ship])

#objects-at-closest-target
(test *)
(run *)	(objects in subsector 3 4 6 5 into [#closest-target])

#object-at-near-target
(test *)
(run *)	(top object in subsector 3 4 2 3 into #near-target)

#object-at-far-target
(test *)
(run *)	(top object in subsector 4 3 3 2 into #far-target)

#object-at-empty-position
(test *)
(run *)	(objects in subsector 8 8 10 10 into [])

#objects-in-star-system
(test *)
(run *)	(objects in subsector 5 5 8 8 into [#sun #planet #other-planet])

#top-object-is-star
(test *)
(run *)	(top object in subsector 5 5 8 8 into #sun)
