%% dgdebug -u damage-tests.dg damage.dg test-ships.dg no-maneuver.dg \
%% 		   	  sector.dg grid.dg unit.dg stdlib.dg

(list of tests [
	#shields
	#shield-levels
	#shield-level-north
	#shield-level-east
	#shield-level-south
	#shield-level-west
	#ammo
	#damaged-systems
	#destroyed-systems
	#undestroyed-systems
	#damaged-systems-simple
	#destroyed-systems-simple
	#test-ship-isnt-simple
	#closest-target-is-simple
	#near-target-is-simple
	#decrease-ammo
	#decrease-ammo-below-zero
	#decrease-shields
	#decrease-shields-below-zero
	#regenerate-shields
	#regenerate-shields-above-max
	#dont-find-damaged-torpedo
	#increase-repair-time-tractor
	#increase-repair-time-mtd
	#decrease-repair-time-tractor
	#decrease-repair-time-beyond-zero
	#decrease-repair-time-mtd
	#repair-tractor
	#destroy-ship
	#test-ship-is-not-destroyed
    #shields-hold-from-ahead-50
    #shields-penetrated-from-ahead-101
    #shields-hold-from-port-50
    #shields-penetrated-from-port-101
	#energy-depleted-from-port-550
	#energy-depleted-from-ahead-600
	#penetrating-shields-damages-system
	#damage-projector-with-300
	#damage-tractor-with-300
	#damage-mtd-with-300
	#damage-tractor-to-destruction
	#wreck-with-300
	#wreck-closest-target-with-500
	#destroy-test-ship
    ])

%% ----------------------------------------------------------------------

(reset randomness)

(interface (code $))

(interface (type $))

(interface (stellar object $))

(interface (base $))

%% ----------------------------------------------------------------------

(test #shields)
	  (#test-ship shields 500)

(test #shield-levels)
	  (#test-ship shield levels [100 99 98 97])

(test #shield-level-north)
	  (#test-ship shield level #north into 100)

(test #shield-level-east)
	  (#test-ship shield level #east into 99)

(test #shield-level-south)
	  (#test-ship shield level #south into 98)

(test #shield-level-west)
	  (#test-ship shield level #west into 97)

(test #ammo)
	  (#test-ship ammo 10)

(test #decrease-ammo)
	  (decrease ammo for #test-ship by 3)
	  (#test-ship ammo 7)

(test #decrease-ammo-below-zero)
	  ~(decrease ammo for #test-ship by 11)

(test #decrease-shields)
	  (decrease shields for #test-ship by 50)
	  (#test-ship shields 450)

(test #decrease-shields-below-zero)
	  ~(decrease shields for #test-ship by 501)

(test #regenerate-shields)
	  (decrease shields for #test-ship by 50)
	  (#test-ship shields 450)
	  (regenerate shields for #test-ship by 50)
	  (#test-ship shields 500)

(test #regenerate-shields-above-max)
	  (decrease shields for #test-ship by 50)
	  (#test-ship shields 450)
	  (regenerate shields for #test-ship by 100)
	  (#test-ship shields 500)

(test #damaged-systems)
	  (#test-ship damaged systems [[#tractor 1 800]])

(test #destroyed-systems)
	  (#test-ship destroyed systems [[#mtd 1 16383]])

(test #undestroyed-systems)
	  (#test-ship undestroyed systems $List)
	  (length of $List into 23)

(test #damaged-systems-simple)
	  (#closest-target damaged systems [])

(test #destroyed-systems-simple)
	  (#closest-target destroyed systems [])

(test #test-ship-isnt-simple)
	  ~(#test-ship is simple)

(test #closest-target-is-simple)
	  (#closest-target is simple)

(test #near-target-is-simple)
	  (#near-target is simple)

(test #dont-find-damaged-torpedo)
	  (increase repair time for #test-ship #torpedo 1 by 30)
	  (find undamaged #torpedo for #test-ship into [[#torpedo 2 [1 8] 1 500]])

(test #increase-repair-time-tractor)
	  (#test-ship systems $Before)
	  (length of $Before into $LenBefore)
	  (increase repair time for #test-ship #tractor 1 by 200)
	  (#test-ship #tractor 1 repair time 1000)
	  (#test-ship systems $After)
	  (length of $After into $LenAfter)
	  (assert $LenBefore = $LenAfter)

(test #increase-repair-time-mtd)
	  (increase repair time for #test-ship #mtd 1 by 200)
	  (#test-ship #mtd 1 repair time 16383)

(test #decrease-repair-time-tractor)
	  (#test-ship systems $Before)
	  (length of $Before into $LenBefore)
	  (decrease repair time for #test-ship #tractor 1 by 200)
	  (#test-ship #tractor 1 repair time 600)
	  (#test-ship systems $After)
	  (length of $After into $LenAfter)
	  (assert $LenBefore = $LenAfter)

(test #decrease-repair-time-beyond-zero)
	  (decrease repair time for #test-ship #tractor 1 by 900)
	  (#test-ship #tractor 1 repair time 0)

(test #decrease-repair-time-mtd)
	  ~(decrease repair time for #test-ship #mtd 1 by 900)

(test #repair-tractor)
	  (repair #test-ship #tractor 1)
	  (#test-ship #tractor 1 repair time 0)

(test #destroy-ship)
	  (destroy #test-ship)
	  (#test-ship is destroyed)

(test #test-ship-is-not-destroyed)
	  ~(#test-ship is destroyed)

(assert $Ship has $Shields and $Energy)
	  ($Ship shields $Shields) $Shields
	  ($Ship energy $Energy) $Energy

(test #shields-hold-from-ahead-50)
      (hit #closest-target with 50 from #north)
      (assert #closest-target has 200 and 500)

(test #shields-penetrated-from-ahead-101)
      (hit #closest-target with 101 from #north)
      (assert #closest-target has 150 and 499)

(test #shields-hold-from-port-50)
      (hit #closest-target with 50 from #west)
      (assert #closest-target has 200 and 500)

(test #shields-penetrated-from-port-101)
      (hit #closest-target with 101 from #west)
      (assert #closest-target has 200 and 449)

(test #energy-depleted-from-port-550)
      (hit #closest-target with 550 from #west)
	  (assert #closest-target has 200 and 0)

(test #energy-depleted-from-ahead-600)
      (hit #closest-target with 600 from #north)
	  (assert #closest-target has 150 and 0)

(test #penetrating-shields-damages-system)
      (hit #test-ship with 150 from #north)
	  (assert #test-ship has 400 and 882)
	  (#test-ship damaged systems $Systems) $Systems
	  (length of $Systems into $Length) $Length
	  (assert $Length = 2)

(test #damage-projector-with-300)
	  (damage #test-ship system #projector 1 with 300)
	  (#test-ship #projector 1 repair time 300)

(test #damage-tractor-with-300)
	  (damage #test-ship system #tractor 1 with 300)
	  (#test-ship #tractor 1 repair time 1100)

(test #damage-mtd-with-300)
	  (damage #test-ship system #mtd 1 with 300)
	  (#test-ship #mtd 1 repair time 16383)

(test #damage-tractor-to-destruction)
	  (damage #test-ship system #tractor 1 with 16300)
	  (#test-ship #tractor 1 repair time 16383)

(test #wreck-with-300)
	  (#test-ship systems $Before)
	  (length of $Before into $Length)
	  (wreck #test-ship with 300 from #north)
	  (#test-ship systems $After)
	  ~(length of $After into $Length)
	  ~($Before = $After)

(test #wreck-closest-target-with-500)
	  (wreck #closest-target with 500 from #north)
	  (#closest-target is destroyed)

(test #destroy-test-ship)
