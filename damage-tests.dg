%% dgdebug -u damage-tests.dg damage.dg schema.dg sectored-grid.dg \
%%            unit.dg stdlib.dg

(list of tests [
      #shields-hold-from-ahead-50
      #shields-penetrated-from-ahead-101
      #shields-hold-from-port-50
      #shields-penetrated-from-port-101
	  #energy-depleted-from-port-550
	  #energy-depleted-from-ahead-600
	  #penetrating-shields-damages-system
	  #damage-projector-with-300
	  #damage-tractor-with-300
	  #damage-mtd-with-300
	  #damage-tractor-to-destruction
	  #wreck-with-300
      ])

%% ----------------------------------------------------------------------

%% state = [ PositionX PositionY Heading Speed DestX DestY Helm Throttle
%% 		   	 Class Energy Crystals Ammo Shields [S1 S2 S3 S4] [Systems]
%%			 DefaultArc DefaultMissiles ]

#test-ship
(grid object *)
(* initial state [344 454 315 400 300 400 315 400 #cygnus-class])

#cygnus-class
(name *)	Cygnus
(type *)	fast scout
(* state [0 0 180 0 500 963 0 0
		 #cygnus-class 1000 4 10 500 [100 99 98 97]
		 [[#projector 1 [360 #up] 100 141 0]
		 [#torpedo 1 [1 8] 1 500 0]
		 [#torpedo 2 [1 8] 1 500 0]
		 [#tractor 1 360 250 0 800]
		 [#sensor 2 [1 8] 2 0 0]
		 [#sensor 1 [360 #up #down] 1 0 0]
		 [#sensor 0 [360 #up #down] 1 0 0]
		 [#mtd 1 #down 4 0 16383]
		 [#shuttle 1 #south 10 0 0]
		 [#life-support 1 360 20 1100 0]
		 [#life-support 2 360 20 10 0]
		 [#reactor 1 360 4 4 0]
		 [#bus 1 360 1000 0 0]
		 [#reactionless #east #south 0 0 0]
		 [#reactionless #west #south 0 0 0]
		 [#a-drive #east [1 2 3 4] 0 0 0]
		 [#a-drive #west [5 6 7 8] 0 0 0]
		 [#damage-control 1 360 3 0 0]
		 [#quarters 1 360 16 0 0]
		 [#lab 1 360 4 0 0]
		 ]])

#closest-target
(grid object *)
(* initial state [355 445 225 200 0 0 225 200 #attack-class])

#near-target
(grid object *)
(* initial state [314 424 45 300 0 0 45 310 #attack-class])

#attack-class
(name *)	Attack
(type *)	attack ship
(* state [0 0 90 100 200 751 0 0
   		  #attack-class 500 2 0 250 [100 50 50 50]
		  [[#projector 1 360 250 141 0]
		  [#reactor 1 360 4 4 0]]])

(set up $)
	 (reset randomness)
	 (exhaust) {
	     *(grid object $Ship)
	     ($Ship initial state $State)
	     (now) ($Ship state $State) %% add this to (initialize $ as $)
		 ($Ship class $Class)
	 	 (initialize $Ship as $Class)
	 }

%% ----------------------------------------------------------------------

(assert $Ship has $Shields and $Energy)
	  ($Ship shields $Shields)
	  $Shields
	  ($Ship energy $Energy)
	  $Energy

(test #shields-hold-from-ahead-50)
      (hit #closest-target with 50 from #north)
      (assert #closest-target has 200 and 500)

(test #shields-penetrated-from-ahead-101)
      (hit #closest-target with 101 from #north)
      (assert #closest-target has 150 and 499)

(test #shields-hold-from-port-50)
      (hit #closest-target with 50 from #west)
      (assert #closest-target has 200 and 500)

(test #shields-penetrated-from-port-101)
      (hit #closest-target with 101 from #west)
      (assert #closest-target has 200 and 449)

(test #energy-depleted-from-port-550)
      (hit #closest-target with 550 from #west)
	  (assert #closest-target has 200 and 0)

(test #energy-depleted-from-ahead-600)
      (hit #closest-target with 600 from #north)
	  (assert #closest-target has 150 and 0)

(test #penetrating-shields-damages-system)
      (hit #closest-target with 150 from #north)
	  (assert #closest-target has 150 and 450)
	  (#closest-target systems $Systems)
	  (take from $Systems where element 6 is 100 into $Damaged)
	  (length of $Damaged into 1)

(test #damage-projector-with-300)
	  (damage #test-ship system #projector 1 with 300)
	  (#test-ship #projector 1 repair time 600)

(test #damage-tractor-with-300)
	  (damage #test-ship system #tractor 1 with 300)
	  (#test-ship #tractor 1 repair time 1400)

(test #damage-mtd-with-300)
	  (damage #test-ship system #mtd 1 with 300)
	  (#test-ship #mtd 1 repair time 16383)

(test #damage-tractor-to-destruction)
	  (damage #test-ship system #tractor 1 with 16300)
	  (#test-ship #tractor 1 repair time 16383)

(test #wreck-with-300)
	  (wreck #test-ship with 300 from #north)
	  (#test-ship systems $Systems)
	  (take from $Systems where element 6 is 16383 into $Destroyed)
	  (length of $Destroyed into $Num)
	  $Num destroyed systems
