#helm
(test *)
(run *)    (#test-ship helm setting 315)

#throttle
(test *)
(run *)    (#test-ship throttle setting 171)

#throttle-gradient
(test *)
(run *)    (#test-ship throttle gradient 7)

#warp-gradient
(test *)
(run *)	  (#test-ship warp gradient 4)

#destination
(test *)
(run *)	   (#test-ship destination [3000 4000])

#has-destination
(test *)
(run *)    (#test-ship has a set destination)

#closest-target-doesnt-have-destination
(test *)
(run *)    ~(#closest-target has a set destination)

#near-target-has-destination
(test *)
(run *)    (#near-target has a set destination)

#far-target-doesnt-have-destination
(test *)
(run *)    ~(#far-target has a set destination)

#distant-target-doesnt-have-destination
(test *)
(run *)    ~(#distant-target has a set destination)

#closest-target-doesnt-have-pursuit
(test *)
(run *)    ~(#closest-target has a pursuit target)

#near-target-doesnt-have-pursuit
(test *)
(run *)    ~(#near-target has a pursuit target)

#far-target-has-pursuit
(test *)
(run *)    (#far-target has a pursuit target)

#distant-target-has-pursuit
(test *)
(run *)    (#distant-target has a pursuit target)

#turn-mode
(test *)
(run *)	   (#test-ship turn mode 180)

#effective-turn-mode
(test *)
(run *)	   (#test-ship effective turn mode 45)

#effective-turn-mode-sublight
(test *)
(run *)
	  (accelerate #test-ship to speed 0)
	  (#test-ship effective turn mode 360)

#drive-efficiency
(test *)
(run *)	   (#test-ship drive efficiency 10)

#reactor-efficiency
(test *)
(run *)	   (#test-ship reactor efficiency 10)

#drive-params
(test *)
(run *)	   (#test-ship drive parameters 9632)

#top-speed
(test *)
(run *)	   (#test-ship top speed 9)

#cruising-speed
(test *)
(run *)	   (#test-ship cruising speed 6)

#acceleration
(test *)
(run *)	   (#test-ship acceleration 3)

#reactionless
(test *)
(run *)	   (#test-ship reactionless 2)

#set-destination
(test *)
(run *)
	(set destination for #test-ship to [4544 5644])
	(#test-ship has a set destination)
	(#test-ship destination [4544 5644])
	(#test-ship heading 315)
	(#test-ship helm setting 135)

#clear-destination
(test *)
(run *)
    (clear destination for #test-ship)
	~(#test-ship has a set destination)
	(#test-ship destination [16383 16383])

#set-pursuit
(test *)
(run *)
    (#test-ship pursues #far-target)
	(#test-ship has a pursuit target)
	~(#test-ship has a set destination)
	(#test-ship destination [#far-target #in])
	(#test-ship helm setting 30)

#set-evasion
(test *)
(run *)
    (#test-ship flees #near-target)
	(#test-ship has a pursuit target)
	~(#test-ship has a set destination)
	(#test-ship destination [#near-target #out])
	(#test-ship helm setting 135)

#set-helm
(test *)
(run *)
	(set helm for #test-ship to 135)
	(#test-ship helm setting 135)

#set-throttle-speed
(test *)
(run *)
	(set throttle for #test-ship to speed 150)
	(#test-ship throttle setting 150)

#set-throttle-speed-too-fast
(test *)
(run *)
	(set throttle for #test-ship to speed 600)
	(#test-ship throttle setting 364)

#set-throttle-gradient
(test *)
(run *)
	(set throttle for #test-ship to gradient 6)
	(#test-ship throttle setting 108)

#set-throttle-gradient-too-fast
(test *)
(run *)
	(set throttle for #test-ship to gradient 10)
	(#test-ship throttle setting 364)

#accelerate
(test *)
(run *)
	  (accelerate #test-ship to speed 171)
	  (#test-ship speed 171)

#accelerate-too-fast
(test *)
(run *)
	  (accelerate #test-ship to speed 500)
	  (#test-ship speed 364)

#decelerate
(test *)
(run *)
	  (accelerate #test-ship to speed 0)
	  (#test-ship speed 0)

#accelerate-gradient
(test *)
(run *)
	  (accelerate #test-ship to gradient 6)
	  (#test-ship warp gradient 6)

#accelerate-gradient-too-fast
(test *)
(run *)
	  (accelerate #test-ship to gradient 10)
	  (#test-ship warp gradient 9)

#decelerate-gradient
(test *)
(run *)
	  (accelerate #test-ship to gradient 0)
	  (#test-ship speed 0)

#regenerate
(test *)
(run *)
	  (regenerate energy for #test-ship)
	  (#test-ship energy 972)

#regenerate-above-max
(test *)
(run *)
	  (regenerate energy for #test-ship)
	  (regenerate energy for #test-ship)
	  (#test-ship energy 1000)

#turn-ship
(test *)
(run *)
	(turn #test-ship to helm setting)
	(#test-ship heading 315)

#turn-ship-to-starboard
(test *)
(run *)
	(set helm for #test-ship to 359)
	(#test-ship heading 315)
	(turn #test-ship to helm setting)
	(#test-ship heading 359)

#turn-ship-to-port
(test *)
(run *)
	(set helm for #test-ship to 270)
	(turn #test-ship to helm setting)
	(#test-ship heading 270)

#turn-ship-about
(test *)
(run *)
	(set helm for #test-ship to 135)
	(turn #test-ship to helm setting)
	(#test-ship heading 0)
	(turn #test-ship to helm setting)
	(#test-ship heading 45)
	(turn #test-ship to helm setting)
	(#test-ship heading 90)
	(turn #test-ship to helm setting)
	(#test-ship heading 135)
	(turn #test-ship to helm setting)
	(#test-ship heading 135)

#turn-ship-to-starboard-too-hard
(test *)
(run *)
	(set helm for #test-ship to 45)
	(turn #test-ship to helm setting)
	(#test-ship heading 0)

#turn-ship-to-port-too-hard
(test *)
(run *)
	(set helm for #test-ship to 225)
	(turn #test-ship to helm setting)
	(#test-ship heading 270)

#accelerate
(test *)
(run *)
	(accelerate #test-ship to throttle setting)
	(#test-ship speed 700)
	(#test-ship warp gradient 7)

#accelerate-too-fast
(test *)
(run *)
	(set throttle for #test-ship to gradient 9)
	(accelerate #test-ship to throttle setting)
	(#test-ship warp gradient 7)
	(accelerate #test-ship to throttle setting)
	(#test-ship warp gradient 9)

#accelerate-way-too-fast
(test *)
(run *)
	(set throttle for #test-ship to gradient 10)
	(accelerate #test-ship to throttle setting)
	(#test-ship warp gradient 7)
	(accelerate #test-ship to throttle setting)
	(#test-ship warp gradient 9)

#decelerate
(test *)
(run *)
	(set throttle for #test-ship to speed 0)
	(accelerate #test-ship to throttle setting)
	(#test-ship warp gradient 0)

