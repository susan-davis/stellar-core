%% dgdebug -u maneuver-tests.dg test-ships.dg maneuvering.dg sector.dg grid.dg \
%%            unit.dg stdlib.dg

(reset randomness)

(interface (code $))

(interface (ship type $))

%% ---------------------------------------------------------------------------

#helm
(test *)
(run *)    (#test-ship helm setting 315)

#throttle
(test *)
(run *)    (#test-ship throttle setting 700)

#throttle-gradient
(test *)
(run *)    (#test-ship throttle gradient 7)

#destination
(test *)
(run *)	   (#test-ship destination [300 400])

#destination-subsector
(test *)
(run *)	   (#test-ship destination 3 4 1 1)

#destination-precisely
(test *)
(run *)	   (#test-ship destination 3 4 1 1 1 1)

#has-destination
(test *)
(run *)    (#test-ship has a set destination)

#closest-target-doesnt-have-destination
(test *)
(run *)    ~(#closest-target has a set destination)

#near-target-has-destination
(test *)
(run *)    (#near-target has a set destination)

#far-target-doesnt-have-destination
(test *)
(run *)    ~(#far-target has a set destination)

#distant-target-doesnt-have-destination
(test *)
(run *)    ~(#distant-target has a set destination)

#closest-target-doesnt-have-pursuit
(test *)
(run *)    ~(#closest-target has a pursuit target)

#near-target-doesnt-have-pursuit
(test *)
(run *)    ~(#near-target has a pursuit target)

#far-target-has-pursuit
(test *)
(run *)    (#far-target has a pursuit target)

#distant-target-has-pursuit
(test *)
(run *)    (#distant-target has a pursuit target)

#turn-mode
(test *)
(run *)	   (#test-ship turn mode 180)

#effective-turn-mode
(test *)
(run *)	   (#test-ship effective turn mode 45)

#effective-turn-mode-sublight
(test *)
(run *)
	  (accelerate #test-ship to speed 0)
	  (#test-ship effective turn mode 360)

#drive-params
(test *)
(run *)	   (#test-ship drive parameters [500 963])

#efficiency
(test *)
(run *)	   (#test-ship drive efficiency 500)

#cruising-speed
(test *)
(run *)	   (#test-ship cruising speed 6)

#top-speed
(test *)
(run *)	   (#test-ship top speed 9)

#acceleration
(test *)
(run *)	   (#test-ship acceleration 300)

#set-destination
(test *)
(run *)
	(position for 4 5 6 7 into $Position)
	(set destination for #test-ship to $Position)
	(#test-ship has a set destination)
	(#test-ship destination 4 5 6 7)
	(#test-ship heading 315)
	(#test-ship helm setting 135)

#set-destination-subsector
(test *)
(run *)
	(set destination for #test-ship to 4 5 6 7)
	(#test-ship has a set destination)
	(#test-ship destination $There)
	([454 564 | $] = $There)
	(#test-ship helm setting 135)

#set-destination-precisely
(test *)
(run *)
	(set destination for #test-ship to 4 5 6 7 8 9)
	(#test-ship has a set destination)
	(#test-ship destination 4 5 6 7 8 9)
	(#test-ship helm setting 137)

#clear-destination
(test *)
(run *)
    (clear destination for #test-ship)
	~(#test-ship has a set destination)
	(#test-ship destination [16383 16383])

#set-pursuit
(test *)
(run *)
    (#test-ship pursues #far-target)
	(#test-ship has a pursuit target)
	~(#test-ship has a set destination)
	(#test-ship destination [#far-target #in])
	(#test-ship helm setting 30)

#set-evasion
(test *)
(run *)
    (#test-ship flees #near-target)
	(#test-ship has a pursuit target)
	~(#test-ship has a set destination)
	(#test-ship destination [#near-target #out])
	(#test-ship helm setting 135)

#set-helm
(test *)
(run *)
	(set helm for #test-ship to 135)
	(#test-ship helm setting 135)

#set-throttle-speed
(test *)
(run *)
	(set throttle for #test-ship to speed 610)
	(#test-ship throttle setting 610)

#set-throttle-speed-too-fast
(test *)
(run *)
	(set throttle for #test-ship to speed 1099)
	(#test-ship throttle setting 900)

#set-throttle-gradient
(test *)
(run *)
	(set throttle for #test-ship to gradient 6)
	(#test-ship throttle setting 600)

#set-throttle-gradient-too-fast
(test *)
(run *)
	(set throttle for #test-ship to gradient 10)
	(#test-ship throttle setting 900)

#accelerate
(test *)
(run *)
	  (accelerate #test-ship to speed 600)
	  (#test-ship speed 600)

#accelerate-too-fast
(test *)
(run *)
	  (accelerate #test-ship to speed 1000)
	  (#test-ship speed 900)

#decelerate
(test *)
(run *)
	  (accelerate #test-ship to speed 0)
	  (#test-ship speed 0)

#accelerate-gradient
(test *)
(run *)
	  (accelerate #test-ship to gradient 6)
	  (#test-ship warp gradient 6)

#accelerate-gradient-too-fast
(test *)
(run *)
	  (accelerate #test-ship to gradient 10)
	  (#test-ship warp gradient 9)

#decelerate-gradient
(test *)
(run *)
	  (accelerate #test-ship to gradient 0)
	  (#test-ship speed 0)

#turn-ship
(test *)
(run *)
	(turn #test-ship to helm setting)
	(#test-ship heading 315)

#turn-ship-to-starboard
(test *)
(run *)
	(set helm for #test-ship to 359)
	(#test-ship heading 315)
	(turn #test-ship to helm setting)
	(#test-ship heading 359)

#turn-ship-to-port
(test *)
(run *)
	(set helm for #test-ship to 270)
	(turn #test-ship to helm setting)
	(#test-ship heading 270)

#turn-ship-about
(test *)
(run *)
	(set helm for #test-ship to 135)
	(turn #test-ship to helm setting)
	(#test-ship heading 0)
	(turn #test-ship to helm setting)
	(#test-ship heading 45)
	(turn #test-ship to helm setting)
	(#test-ship heading 90)
	(turn #test-ship to helm setting)
	(#test-ship heading 135)
	(turn #test-ship to helm setting)
	(#test-ship heading 135)

#turn-ship-to-starboard-too-hard
(test *)
(run *)
	(set helm for #test-ship to 45)
	(turn #test-ship to helm setting)
	(#test-ship heading 0)

#turn-ship-to-port-too-hard
(test *)
(run *)
	(set helm for #test-ship to 225)
	(turn #test-ship to helm setting)
	(#test-ship heading 270)

#accelerate
(test *)
(run *)
	(accelerate #test-ship to throttle setting)
	(#test-ship speed 700)
	(#test-ship warp gradient 7)

#accelerate-too-fast
(test *)
(run *)
	(set throttle for #test-ship to gradient 9)
	(accelerate #test-ship to throttle setting)
	(#test-ship warp gradient 7)
	(accelerate #test-ship to throttle setting)
	(#test-ship warp gradient 9)

#accelerate-way-too-fast
(test *)
(run *)
	(set throttle for #test-ship to gradient 10)
	(accelerate #test-ship to throttle setting)
	(#test-ship warp gradient 7)
	(accelerate #test-ship to throttle setting)
	(#test-ship warp gradient 9)

#decelerate
(test *)
(run *)
	(set throttle for #test-ship to speed 0)
	(accelerate #test-ship to throttle setting)
	(#test-ship warp gradient 0)

#energy-for-warp-4
(test *)
(run *)
	(#test-ship energy needed for distance 400 into 1)

#energy-for-warp-8
(test *)
(run *)
	(#test-ship energy needed for distance 800 into 6)

#move-on-course
(test *)
(run *)
	(move #test-ship on course and speed)
	(#test-ship position [315 425 | $])

#move-on-course-closest-target
(test *)
(run *)
	(turn #test-ship to face #closest-target)
	(move #test-ship on course and speed)
	(#test-ship position [373 425 | $])

#move-on-course-distant-target
(test *)
(run *)
	(turn #test-ship to face #distant-target)
	(move #test-ship on course and speed)
	(#test-ship position [331 489 | $])

(assert energy $Energy yields throttle $Throttle)
	(932 minus $Energy into $Deficit)
	(decrease energy for #test-ship by $Deficit)
	(adjust #test-ship throttle for remaining energy)
	(#test-ship throttle setting $Throttle)

#adjust-throttle-932
(test *)
(run *)    (assert energy 932 yields throttle 700)

#adjust-throttle-6
(test *)
(run *)    (assert energy 6 yields throttle 700)

#adjust-throttle-1
(test *)
(run *)    (assert energy 1 yields throttle 500)

#adjust-throttle-0
(test *)
(run *)    (assert energy 0 yields throttle 0)

(assert $Target goes to $SX $SY $X $Y heading $H speed $S energy $E)
    (if) ($Target position $Destination) (then)
        (set destination for #test-ship to $Destination)
    (endif)
    (update #test-ship position and velocity)
    (#test-ship subsector into $SX $SY $X $Y)
	(#test-ship heading $H)
	(#test-ship speed $S)
	(#test-ship energy $E)

#update-ship-near-target
(test *)
(run *)
	(assert #near-target goes to 3 4 2 3 heading 315 speed 700 energy 972)

#update-ship-far-target
(test *)
(run *)
	(assert #far-target goes to 3 3 5 9 heading 0 speed 700 energy 968)

#update-ship-distant-target
(test *)
(run *)
	(assert #distant-target goes to 2 4 8 6 heading 270 speed 700 energy 968)

(assert $N minutes goes to $X $Y at throttle $Throttle)
	(set throttle for #test-ship to gradient $Throttle)
	(move #test-ship for $N minutes)
	(#test-ship position $Pos) $Pos
	(assert $Pos = [$X $Y])

#move-straight-1-at-7
(test *)
(run *)
	(clear #test-ship destination)
    (assert 1 minutes goes to 294 404 at throttle 7)

#move-straight-2-at-7
(test *)
(run *)
	(clear #test-ship destination)
	(assert 2 minutes goes to 244 354 at throttle 7)

#move-1-at-7
(test *)
(run *)    (assert 1 minutes goes to 294 404 at throttle 7)

#move-2-at-7
(test *)
(run *)    (assert 2 minutes goes to 244 354 at throttle 7)

#move-5-at-7
(test *)
(run *)    (assert 5 minutes goes to 94 204 at throttle 7)

#move-8-at-4
(test *)
(run *)    (assert 8 minutes goes to 112 222 at throttle 4)

(assert $N minutes toward $Destination goes to $SX $SY $X $Y $PX $PY)
	(set destination for #test-ship to $Destination)
	(set throttle for #test-ship to gradient 4)
	(move #test-ship for $N minutes)
	(#test-ship coordinates into $SX $SY $X $Y $PX $PY)

#move-1-toward-corner
(test *)
(run *)    (assert 1 minutes toward [899 899] goes to 3 4 5 2 5 5)

#move-2-toward-corner
(test *)
(run *)    (assert 2 minutes toward [899 899] goes to 3 3 8 9 4 6)

#move-5-toward-corner
(test *)
(run *)    (assert 5 minutes toward [899 899] goes to 4 4 8 4 4 8)

#pursue-far-target
(test *)
(run *)
	 (range from #test-ship to #far-target into 1894)
	 (#test-ship pursues #far-target)
	 (set throttle for #test-ship to gradient 4)
	 (move #test-ship for 3 minutes)
	 (#test-ship position $Pos) $Pos
	 (range from #test-ship to #far-target into $R) $R

#evade-near-target
(test *)
(run *)
	 (range from #test-ship to #near-target into 424)
	 (#test-ship flees #near-target)
	 (set throttle for #test-ship to gradient 4)
	 (move #test-ship for 3 minutes)
	 (#test-ship position $Pos) $Pos
	 (range from #test-ship to #far-target into $R) $R
