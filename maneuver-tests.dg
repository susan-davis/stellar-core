(assert energy $Energy yields throttle $Throttle)
	(932 minus $Energy into $Deficit)
	(decrease energy for #test-ship by $Deficit)
	(adjust #test-ship throttle for remaining energy)
	(#test-ship throttle setting $Throttle)

#adjust-throttle-932
(test *)
(run *)    (assert energy 932 yields throttle 171)

#adjust-throttle-6
(test *)
(run *)    (assert energy 6 yields throttle 60)

#adjust-throttle-1
(test *)
(run *)    (assert energy 1 yields throttle 10)

#adjust-throttle-0
(test *)
(run *)    (assert energy 0 yields throttle 0)

#move-on-course
(test *)
(run *)
	(move #test-ship on course and speed)
	(#test-ship position [3424 4524 315 32])

#move-on-course-closest-target
(test *)
(run *)
	(turn #test-ship to face #closest-target)
	(move #test-ship on course and speed)
	(#test-ship position [3464 4524 45 32])

#move-on-course-distant-target
(test *)
(run *)
	(turn #test-ship to face #distant-target)
	(move #test-ship on course and speed)
	(#test-ship position [3444 4574 200 32])

(assert $Target goes to $Pos)
    (if) ($Target position $Destination) (then)
        (set destination for #test-ship to $Destination)
    (endif)
    (update #test-ship position and velocity)
    (#test-ship position $Pos)

#update-ship-near-target
(test *)
(run *)
	(assert #near-target goes to [3414 4514 315 35])

#update-ship-far-target
(test *)
(run *)
	(assert #far-target goes to [3444 4504 0 35])

#update-ship-distant-target
(test *)
(run *)
	(assert #distant-target goes to [3404 4544 270 35])

(assert $N minutes goes to $X $Y at throttle $Throttle)
	(clear destination for #test-ship)
	(set throttle for #test-ship to gradient $Throttle)
	(move #test-ship for $N minutes)
	(#test-ship position $Pos)
	($Pos = [$X $Y | $])

#move-1-at-7
(test *)
(run *)    (assert 1 minutes goes to 3414 4514 at throttle 7)

#move-2-at-7
(test *)
(run *)    (assert 2 minutes goes to 3384 4484 at throttle 7)

#move-5-at-7
(test *)
(run *)    (assert 5 minutes goes to 3294 4394 at throttle 7)

#move-8-at-4
(test *)
(run *)    (assert 8 minutes goes to 3284 4384 at throttle 4)

(assert $N minutes toward $Destination goes to $X $Y)
	(set destination for #test-ship to $Destination)
	(set throttle for #test-ship to gradient 6)
	(move #test-ship for $N minutes)
	(#test-ship position $Pos)
	($Pos = [$X $Y | $])

#move-1-toward-corner
(test *)
(run *)    (assert 1 minutes toward [8999 8999] goes to 3444 4504)

#move-2-toward-corner
(test *)
(run *)    (assert 2 minutes toward [8999 8999] goes to 3474 4474)

#move-5-toward-corner
(test *)
(run *)    (assert 5 minutes toward [8999 8999] goes to 3574 4534)

#pursue-far-target
(test *)
(run *)
	 (range from #test-ship to #far-target into 1894)
	 (#test-ship pursues #far-target)
	 (set throttle for #test-ship to gradient 6)
	 (move #test-ship for 3 minutes)
	 (#test-ship position [3504 4444 30 41])
	 (range from #test-ship to #far-target into 1802)

#evade-near-target
(test *)
(run *)
	 (range from #test-ship to #near-target into 424)
	 (#test-ship flees #near-target)
	 (set throttle for #test-ship to gradient 6)
	 (move #test-ship for 3 minutes)
	 (#test-ship position [3514 4474 90 41])
	 (range from #test-ship to #far-target into 1804)
