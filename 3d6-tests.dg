%% dgdebug -u 3d6-tests.dg 3d6.dg unit.dg stdlib.dg

(list of tests [
	  #one-roll
	  #one-roll-from-start
	  #wrap-around-1d6
	  #two-roll-total
	  #two-roll-individual
	  #die-times-die
	  #three-roll-total
	  #three-roll-individual
	  #wrap-around-3d6
	  #memoize-length
	  #randomize-position
	  ])

%%-----------------------------------------------------------------------------

(set up $)
	 (now) (random list position 0)
	 (now) (single die list position 0)

%%-----------------------------------------------------------------------------

(test #one-roll)
	(one die 1)
	(one die 1)
	(one die 4)
	(one die 2)
	(one die 6)
	(one die 4)
	(one die 1)

(test #one-roll-from-start)
	(now) (single die list position 1)
	(one die 4)
	(one die 5)
	(one die 6)
	(one die 4)
	(one die 3)
	(one die 1)
	(one die 5)

(test #wrap-around-1d6)
 	(now) (single die list position 648)
	(one die 2)
	(one die 4)
	(one die 5)
	(one die 6)

(test #two-roll-total)
	(two dice 9)
	(two dice 7)
	(two dice 8)
	(two dice 11)
	(two dice 5)
	(two dice 6)

(test #two-roll-individual)
    (two dice 4 5)
	(two dice 4 3)
	(two dice 5 3)
	(two dice 6 5)
	(two dice 1 4)
	(two dice 5 1)

(test #die-times-die)
    (d6 times d6 20)
	(d6 times d6 12)
	(d6 times d6 15)
	(d6 times d6 30)
	(d6 times d6 4)
	(d6 times d6 5)

(test #three-roll-total)
	(three dice 15)
	(three dice 8)
	(three dice 14)
	(three dice 17)
	(three dice 11)
	(three dice 11)

(test #three-roll-individual)
	(three dice 4 5 6)
	(three dice 4 3 1)
	(three dice 5 3 6)
	(three dice 6 5 6)
	(three dice 1 4 6)
	(three dice 5 1 5)

(test #wrap-around-3d6)
	(now) (random list position 214)
	(three dice 1 6 5)
	(three dice 2 2 3)
	(three dice 6 1 2)
	(three dice 4 5 6)
	(three dice 4 3 1)

(test #memoize-length)
	(now) (random die rolls [])
	(length of random list 216)

(test #randomize-position)
	(shuffle randomness)
	(random list length $Len)
	(assert $Len = 216)
	(random list position $Pos)
	(assert $Pos > 0)
	(assert $Pos < 217)
	$Pos
