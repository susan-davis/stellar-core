%% dgdebug -u d6-tests.dg d6.dg unit.dg stdlib.dg

(set up $)	 (reset randomness)

#1d3
(test *)
(run *)
	(roll #d3 3)
	(roll #d3 3)
	(roll #d3 2)
	(roll #d3 3)
	(3d6 list position 2)
	(roll #d3 1)
	(roll #d3 2)
	(roll #d3 2)
	(roll #d3 2)
	(3d6 list position 3)
	(roll #d3 3)
	(3d6 list position 4)

#one-roll
(test *)
(run *)
	(3d6 list position 1)
	(roll #d6 6)
	(3d6 list position 2)
	(roll #d6 5)
	(roll #d6 4)
	(roll #d6 6)
	(3d6 list position 2)
	(roll #d6 1)
	(3d6 list position 3)
	~(3d6 has rolled over)

#wrap-around-1d6
(test *)
(run *)
 	(now) (3d6 list position 215)
	(roll #d6 3)
	(roll #d6 2)
	(roll #d6 2)
	(roll #d6 4)
 	(3d6 list position 216)
	(roll #d6 2)
	(roll #d6 1)
	(roll #d6 6)
	(roll #d6 4)
 	(3d6 list position 217)
	(roll #d6 6)
	(3d6 has rolled over)
	(3d6 list position 2)
	(roll #d6 5)
	(roll #d6 4)
	(roll #d6 6)
	(3d6 has rolled over)
	(3d6 list position 2)

#1d6-plus-3
(test *)
(run *)
	(roll 1 #d6 plus 3 9)
	(roll 1 #d6 plus 3 8)
	(roll 1 #d6 plus 3 7)
	(roll 1 #d6 plus 3 9)
	(roll 1 #d6 plus 3 4)

#1d6-minus-3
(test *)
(run *)
	(roll 1 #d6 minus 3 3)
	(roll 1 #d6 minus 3 2)
	(roll 1 #d6 minus 3 1)
	(roll 1 #d6 minus 3 3)
	(roll 1 #d6 minus 3 0)

#two-roll-individual
(test *)
(run *)
	(roll two #d6 5 6)
	(3d6 list position 2)
	(roll two #d6 6 4)
	(3d6 list position 2)
	(roll two #d6 3 1)
	(3d6 list position 3)
	(roll two #d6 3 4)
	(3d6 list position 3)
	(roll two #d6 3 6)
	(3d6 list position 4)

#two-roll-total
(test *)
(run *)
	(roll 2 #d6 11)
	(roll 2 #d6 10)
	(roll 2 #d6 4)
	(roll 2 #d6 7)
	(roll 2 #d6 9)
	(3d6 list position 4)

#three-roll-individual
(test *)
(run *)
	(roll three #d6 4 5 6)
	(roll three #d6 4 3 1)
	(roll three #d6 5 3 6)
	(roll three #d6 6 5 6)
	(roll three #d6 1 4 6)
	(3d6 list position 6)

#three-roll-total
(test *)
(run *)
	(roll 3 #d6 15)
	(roll 3 #d6 8)
	(roll 3 #d6 14)
	(roll 3 #d6 17)
	(roll 3 #d6 11)
	(3d6 list position 6)

#wrap-around-3d6
(test *)
(run *)
	(now) (3d6 list position 215)
	(roll three #d6 2 2 3)
	(roll three #d6 6 1 2)
	(3d6 list position 217)
	~(3d6 has rolled over)
	(roll three #d6 4 5 6)
	(3d6 has rolled over)
	(roll three #d6 4 3 1)
	(roll three #d6 5 3 6)
	(roll three #d6 6 5 6)
	(roll three #d6 1 4 6)
	(3d6 list position 6)

#four-roll-individual
(test *)
(run *)
	(roll 4 #d6 21)
	(roll 4 #d6 11)
	(roll 4 #d6 20)
	(roll 4 #d6 22)
	(roll 4 #d6 15)
	(roll 4 #d6 13)
	(3d6 list position 7)

#four-roll-total
(test *)
(run *)
	(roll four #d6 6 4 5 6)
	(roll four #d6 3 4 3 1)
	(roll four #d6 6 5 3 6)
	(roll four #d6 5 6 5 6)
	(roll four #d6 4 1 4 6)

#four-roll-saved
(test *)
(run *)
	(roll #d6 6)
	(roll three #d6 4 3 1)
	(3d6 list position 3)
	(roll four #d6 6 4 5 3)
	(3d6 list position 3)

#mix-one-and-three
(test *)
(run *)
	(roll #d6 6)
	(roll three #d6 4 3 1)
	(roll #d6 3)
	(roll #d6 5)
	(roll three #d6 5 3 6)
	(roll #d6 6)

#d36
(test *)
(run *)
    (roll #d36 30)
    (roll #d36 34)
    (roll #d36 13)
    (roll #d36 16)
    (roll #d36 18)
	(3d6 list position 4)

#d216
(test *)
(run *)
	(roll #d216 138)
	(roll #d216 121)
	(roll #d216 162)
	(roll #d216 210)
	(roll #d216 24)
	(3d6 list position 6)

#randomize-position
(test *)
(run *)
	(shuffle randomness)
	(3d6 list position $Pos)
	(assert $Pos > 0)
	(assert $Pos < 217)
	(assert $Pos > 0)
	(assert $Pos < 217)
	$Pos

#reset-randomness
(test *)
(run *)
	(roll three #d6 4 5 6)
	(roll three #d6 4 3 1)
	(roll three #d6 5 3 6)
	(reset randomness)
	(saved roll 0)
	(3d6 list position 1)
	(roll three #d6 4 5 6)
	(roll three #d6 4 3 1)
	(roll three #d6 5 3 6)

#2d3-individual
(test *)
(run *)
	(roll two #d3 3 3)
	(roll two #d3 3 2)
	(roll two #d3 2 1)
	(roll two #d3 2 2)
	(roll two #d3 2 3)

#2d3-total
(test *)
(run *)
	(roll 2 #d3 6)
	(roll 2 #d3 5)
	(roll 2 #d3 3)
	(roll 2 #d3 4)
	(roll 2 #d3 5)

#1dF
(test *)
(run *)
	(roll 1dF #up   1)
	(roll 1dF #up   1)
	(roll 1dF 0     0)
	(roll 1dF #up   1)
	(roll 1dF #down 1)

#2dF
(test *)
(run *)
	(roll 2dF #up   2)
	(roll 2dF #up   1)
	(roll 2dF #down 1)
	(roll 2dF 0     0)
	(roll 2dF #up   1)

#1-plus-2dF
(test *)
(run *)
	(1 plus 2dF 3)
	(1 plus 2dF 2)
	(1 plus 2dF 0)
	(1 plus 2dF 1)
	(1 plus 2dF 2)

#4dF
(test *)
(run *)
	(roll 4dF #up   3)
	(roll 4dF #down 1)
	(roll 4dF #up   3)
	(roll 4dF #up   4)
	(roll 4dF 0     0)

#2-plus-4dF
(test *)
(run *)
	(2 plus 4dF 5)
	(2 plus 4dF 1)
	(2 plus 4dF 5)
	(2 plus 4dF 6)
	(2 plus 4dF 2)

#7-die-pool-against-target
(test *)
(run *)
	(roll 7 #d6 with target 5 into 3)
	(roll 7 #d6 with target 5 into 6)
	(roll 7 #d6 with target 5 into 3)
	(roll 7 #d6 with target 5 into 3)

#8-die-pool-against-target
(test *)
(run *)
	(roll 8 #d6 with target 5 into 3)
	(roll 8 #d6 with target 5 into 7)
	(roll 8 #d6 with target 5 into 3)
	(roll 8 #d6 with target 5 into 3)

#9-die-pool-against-target
(test *)
(run *)
	(roll 9 #d6 with target 5 into 4)
	(roll 9 #d6 with target 5 into 5)
	(roll 9 #d6 with target 5 into 5)
	(roll 9 #d6 with target 5 into 3)

#10-die-pool-against-target
(test *)
(run *)
	(roll 10 #d6 with target 5 into 4)
	(roll 10 #d6 with target 5 into 7)
	(roll 10 #d6 with target 5 into 4)
	(roll 10 #d6 with target 5 into 2)

#11-die-pool-against-target
(test *)
(run *)
	(roll 11 #d6 with target 5 into 5)
	(roll 11 #d6 with target 5 into 7)
	(roll 11 #d6 with target 5 into 4)
	(roll 11 #d6 with target 5 into 4)

#11-die-pool-against-higher-target
(test *)
(run *)
	(roll 11 #d6 with target 6 into 3)
	(roll 11 #d6 with target 6 into 3)
	(roll 11 #d6 with target 6 into 3)
	(roll 11 #d6 with target 6 into 0)

#11-die-pool-against-lower-target
(test *)
(run *)
	(roll 11 #d6 with target 4 into 7)
	(roll 11 #d6 with target 4 into 9)
	(roll 11 #d6 with target 4 into 7)
	(roll 11 #d6 with target 4 into 5)

#percent-of-zero
(test *)
(run *)
	(percentage of 0 into 0)

#percent-of-one
(test *)
(run *)
	(percentage of 1 into 1)

#percent-of-two
(test *)
(run *)
	(percentage of 2 into 2)
	(percentage of 2 into 2)
	(percentage of 2 into 2)
	(percentage of 2 into 2)
	(percentage of 2 into 1)

#percent-of-five
(test *)
(run *)
	(percentage of 5 into 5)
	(percentage of 5 into 4)
	(percentage of 5 into 1)
	(percentage of 5 into 3)
	(percentage of 5 into 4)

