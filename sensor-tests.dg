%% dgdebug -u sensor-tests.dg sensor.dg test-ships.dg damage.dg maneuver.dg \
%% 		   	  sector.dg grid.dg d6.dg utils.dg unit.dg stdlib.dg

(reset randomness)
(reset missiles)

(interface (ship type $))  %% silence warnings

(interface (code $))       %% silence warnings

%%-----------------------------------------------------------------------------

#test-ship-is-union
(test *)
(run *)	  (#test-ship fleet #union)

#closest-target-is-quellan
(test *)
(run *)	  (#closest-target fleet #quellan)

#near-target-is-quellan
(test *)
(run *)	  (#near-target fleet #quellan)

#far-target-is-quellan
(test *)
(run *)	  (#far-target fleet #quellan)

#distant-target-is-quellan
(test *)
(run *)	  (#distant-target fleet #quellan)

#closest-target-is-hostile
(test *)
(run *)	  (#test-ship considers #closest-target hostile)

#near-target-is-hostile
(test *)
(run *)	  (#test-ship considers #near-target hostile)

#far-target-is-hostile
(test *)
(run *)	  (#test-ship considers #far-target hostile)

#distant-target-is-hostile
(test *)
(run *)	  (#test-ship considers #distant-target hostile)

#closest-target-finds-test-ship-hostile
(test *)
(run *)	  (#closest-target considers #test-ship hostile)

#closest-target-finds-near-target-friendly
(test *)
(run *)	  (#closest-target considers #near-target friendly)

#closest-target-finds-far-target-friendly
(test *)
(run *)	  (#closest-target considers #far-target friendly)

#closest-target-finds-distant-target-friendly
(test *)
(run *)	  (#closest-target considers #distant-target friendly)

#test-ship-sensors-list
(test *)
(run *)
	(#test-ship undamaged systems $Systems)
	(sensors in $Systems into [
	    [#sensor 5 #north 5]
	    [#sensor 4 [360 #up #down] 4]
	    [#sensor 3 [360 #up #down] 3]])

#sensors-covering-0
(test *)
(run *)
	(#test-ship sensors covering angle 0 into [
	    [#sensor 5 #north 5]
	    [#sensor 4 [360 #up #down] 4]
	    [#sensor 3 [360 #up #down] 3]])

#sensors-covering-135
(test *)
(run *)
	(#test-ship sensors covering angle 135 into [
	    [#sensor 4 [360 #up #down] 4]
	    [#sensor 3 [360 #up #down] 3]])

#best-functioning-sensor-0
(test *)
(run *)
	(#test-ship best functioning sensor for angle 0 into
	    [#sensor 5 #north 5])

#best-functioning-sensor-195
(test *)
(run *)
	(#test-ship best functioning sensor for angle 195 into
	    [#sensor 4 [360 #up #down] 4])

#best-functioning-sensor-closest-target
(test *)
(run *)
	(#test-ship best functioning sensor for target #closest-target into
	    [#sensor 4 [360 #up #down] 4])

#best-functioning-sensor-near-target
(test *)
(run *)
	(#test-ship best functioning sensor for target #near-target into
	    [#sensor 5 #north 5])

#best-functioning-sensor-far-target
(test *)
(run *)
	(#test-ship best functioning sensor for target #far-target into
	    [#sensor 4 [360 #up #down] 4])

#best-functioning-sensor-distant-target
(test *)
(run *)
	(#test-ship best functioning sensor for target #distant-target into
	    [#sensor 4 [360 #up #down] 4])

#best-functioning-sensor-closest-target-position
(test *)
(run *)
	(#closest-target position $Pos)
	(#test-ship best functioning sensor for position $Pos into
	    [#sensor 4 [360 #up #down] 4])

#best-functioning-sensor-near-target-position
(test *)
(run *)
	(#near-target position $Pos)
	(#test-ship best functioning sensor for position $Pos into
	    [#sensor 5 #north 5])

#best-functioning-sensor-far-target-position
(test *)
(run *)
	(#far-target position $Pos)
	(#test-ship best functioning sensor for position $Pos into
	    [#sensor 4 [360 #up #down] 4])

#best-functioning-sensor-distant-target-position
(test *)
(run *)
	(#distant-target position $Pos)
	(#test-ship best functioning sensor for position $Pos into
	    [#sensor 4 [360 #up #down] 4])

#sensor-value-sensor-closest-target
(test *)
(run *)	(#test-ship sensor value for target #closest-target into 4)

#sensor-value-sensor-near-target
(test *)
(run *)	(#test-ship sensor value for target #near-target into 5)

#sensor-value-sensor-far-target
(test *)
(run *)	(#test-ship sensor value for target #far-target into 4)

#sensor-value-sensor-distant-target
(test *)
(run *)	(#test-ship sensor value for target #distant-target into 4)

#closest-target-in-missile-range
(test *)
(run *)	(#closest-target is in missile range of #test-ship)

#near-target-in-missile-range
(test *)
(run *)	(#near-target is in missile range of #test-ship)

#far-target-in-missile-range
(test *)
(run *)	(#far-target is in missile range of #test-ship)

#distant-target-not-in-missile-range
(test *)
(run *)	~(#distant-target is in missile range of #test-ship)

#non-grid-object-not-in-missile-range
(test *)
(run *)	~(#non-grid-object is in missile range of #test-ship)

#asteroid-in-missile-range
(test *)
(run *)	(#asteroid is in missile range of #test-ship)

#closest-target-in-weapons-range
(test *)
(run *)	(#closest-target is in weapons range of #test-ship)

#near-target-in-weapons-range
(test *)
(run *)	(#near-target is in weapons range of #test-ship)

#far-target-not-in-weapons-range
(test *)
(run *)	~(#far-target is in weapons range of #test-ship)

#distant-target-not-in-weapons-range
(test *)
(run *)	~(#distant-target is in weapons range of #test-ship)

#non-grid-object-not-in-weapons-range
(test *)
(run *)	~(#non-grid-object is in weapons range of #test-ship)

#asteroid-in-weapons-range
(test *)
(run *)	(#asteroid is in weapons range of #test-ship)

#closest-target-in-matter-transmission-range
(test *)
(run *)
	(move #closest-target to position [3444 4554])
	(#closest-target is in point defence range of #test-ship)

#near-target-not-in-matter-transmission-range
(test *)
(run *)	~(#near-target is in point defence range of #test-ship)

#far-target-not-in-matter-transmission-range
(test *)
(run *)	~(#far-target is in point defence range of #test-ship)

#distant-target-not-in-matter-transmission-range
(test *)
(run *)	~(#distant-target is in point defence range of #test-ship)

#non-grid-object-not-in-matter-transmission-range
(test *)
(run *)	~(#non-grid-object is in point defence range of #test-ship)

#closest-in-missile-range-of-near
(test *)
(run *) (#closest-target is in missile range of #near-target)

#closest-in-weapons-range-of-near
(test *)
(run *) (#closest-target is in weapons range of #near-target)

#near-out-of-range-of-far
(test *)
(run *) ~(#near-target is in weapons range of #far-target)

#near-out-of-range-of-distant
(test *)
(run *) ~(#near-target is in missile range of #distant-target)

#detected-closest
(test *)
(run *)      (#test-ship has detected #closest-target)

#detected-near
(test *)
(run *)      (#test-ship has detected #near-target)

#detected-far
(test *)
(run *)      (#test-ship has detected #far-target)

#not-detected-distant
(test *)
(run *)      ~(#test-ship has detected #distant-target)

#sensor-lock-closest
(test *)
(run *)      (#test-ship has sensor lock on #closest-target)

#sensor-lock-near
(test *)
(run *)      (#test-ship has sensor lock on #near-target)

#sensor-lock-far
(test *)
(run *)      (#test-ship has sensor lock on #far-target)

#not-sensor-lock-distant
(test *)
(run *)      ~(#test-ship has sensor lock on #distant-target)

#weapons-lock-closest
(test *)
(run *)      (#test-ship has weapons lock on #closest-target)

#weapons-lock-near
(test *)
(run *)      (#test-ship has weapons lock on #near-target)

#not-weapons-lock-far
(test *)
(run *)      ~(#test-ship has weapons lock on #far-target)

#not-weapons-lock-distant
(test *)
(run *)      ~(#test-ship has weapons lock on #distant-target)
