%% dgdebug -u missile-tests.dg test-ships.dg missile.dg weapons.dg sensor.dg
%%            damage.dg arc.dg maneuver.dg schema.dg sector.dg grid.dg
%%            unit.dg stdlib.dg

(interface (ship type $))  %% silence warnings

(interface (code $))       %% silence warnings

%%-----------------------------------------------------------------------------

#launch-missiles
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(list of missiles [[3544 4444 225 499 #test-ship 2 200 4 1]])
	(next missile id 2)

#launch-more-missiles
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(launch 2 missiles of 499 2 200 from [3144 4244] at #test-ship)
	(list of missiles [
	    [3544 4444 225 499 #test-ship 2 200 4 1]
		[3144 4244 135 499 #test-ship 2 200 2 2]])
	(next missile id 3)

#launch-no-missiles
(test *)
(run *)
    (launch 0 missiles of 499 2 200 from [3544 4444] at #test-ship)
    (list of missiles [])

#shoot-down-no-missiles
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(destroy 0 missiles from volley 1)
	(list of missiles [[3544 4444 225 499 #test-ship 2 200 4 1]])

#dont-shoot-down-nonexistent-missiles
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	~(destroy 2 missiles from volley 2)
	(list of missiles [[3544 4444 225 499 #test-ship 2 200 4 1]])

#shoot-down-some-missiles
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(destroy 2 missiles from volley 1)
	(list of missiles [[3544 4444 225 499 #test-ship 2 200 2 1]])

#shoot-down-all-missiles
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(destroy 4 missiles from volley 1)
	(list of missiles [])

#shoot-down-too-many-missiles
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(destroy 16383 missiles from volley 1)
	(list of missiles [])

#shoot-down-ridiculously-many-missiles
(test *)
(run *)
    (launch 16383 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(destroy 16382 missiles from volley 1)
	(list of missiles [[3544 4444 225 499 #test-ship 2 200 1 1]])

#hit-missiles
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3444 4544] at #near-target)
    (hit 1 with 5 from angle 0)
	(list of missiles [[3444 4544 315 499 #near-target 2 200 3 1]])

#hit-missiles-3-times
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3444 4544] at #near-target)
    (hit 1 3 times with 5 from angle 0)
	(list of missiles [[3444 4544 315 499 #near-target 2 200 1 1]])

#hit-missiles-too-softly
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3444 4544] at #near-target)
    (hit 1 with 3 from angle 0)
	(list of missiles [[3444 4544 315 499 #near-target 2 200 4 1]])

#hit-missiles-too-softly-3-times
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3444 4544] at #near-target)
    (hit 1 3 times with 3 from angle 0)
	(list of missiles [[3444 4544 315 499 #near-target 2 200 4 1]])

#fire-torpedo-from-beyond-boost
(test *)
(run *)
    (drag #test-ship to position [3999 4999])
	(drag #near-target to position [3000 4000])
	(#test-ship fires #torpedo at target #near-target using 2)
    (list of missiles [
	    [3219 4219 315 499 #near-target 1 500 1 1]
		[3219 4219 315 499 #near-target 1 500 1 2]])

#remove-volley
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(remove volley 1)
	(list of missiles [])

#remove-nonexistent-volley
(test *)
(run *)
	(remove volley 1)
	(list of missiles [])

#volley-is-destroyed
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(remove volley 1)
	(1 is destroyed)

#volley-is-not-destroyed
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	~(1 is destroyed)

#nonexistent-volley-is-destroyed
(test *)
(run *)
	(1 is destroyed)

#remove-tracking-missiles
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(list of missiles [[3544 4444 225 499 #test-ship 2 200 4 1]])
    (remove all missiles tracking on #test-ship)
	(list of missiles [])

#remove-tracking-missiles-leaving-others
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #neutral-ship)
	(list of missiles [
	    [3544 4444 225 499 #test-ship 2 200 4 1]
	    [3544 4444 118 499 #neutral-ship 2 200 4 2]])
    (remove all missiles tracking on #test-ship)
	(list of missiles [[3544 4444 118 499 #neutral-ship 2 200 4 2]])

#volley-reaches-target
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
    (volley 1 reaches its target)
	(#test-ship shields 104)
	(#test-ship energy 528)
	(#test-ship length of systems 6)

#move-volley-to-target
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(list of missiles [[3544 4444 225 499 #test-ship 2 200 4 1]])
    (update missiles for #test-ship)
	(list of missiles [[3444 4544 225 499 #test-ship 1 200 4 1]])
    (update missiles for #test-ship)
	(#test-ship shields 100)
	(#test-ship energy 532)
	(#test-ship length of systems 6)
	(list of missiles [])

#dont-move-volleys-for-other-ships
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #neutral-ship)
	(list of missiles [
	    [3544 4444 225 499 #test-ship 2 200 4 1]
	    [3544 4444 118 499 #neutral-ship 2 200 4 2]])
    (update missiles for #test-ship)
	(list of missiles [
	    [3544 4444 118 499 #neutral-ship 2 200 4 2]
	    [3444 4544 225 499 #test-ship 1 200 4 1]])
    (update missiles for #test-ship)
	(list of missiles [[3544 4444 118 499 #neutral-ship 2 200 4 2]])

#move-volley-maximum-range
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3999 4999] at #test-ship)
	(list of missiles [[3999 4999 310 499 #test-ship 2 200 4 1]])
    (update missiles for #test-ship)
	(list of missiles [[3639 4639 310 499 #test-ship 1 200 4 1]])
    (update missiles for #test-ship)
	(list of missiles [[3444 4544 295 499 #test-ship 0 200 4 1]])
    (update missiles for #test-ship)
	(#test-ship shields 100)
	(#test-ship energy 532)
	(#test-ship length of systems 6)
	(list of missiles [])

#volley-runs-out-of-fuel
(test *)
(run *)
    (drag #test-ship to position [3000 4000])
    (launch 4 missiles of 499 2 200 from [3999 4999] at #test-ship)
	(list of missiles [[3999 4999 315 499 #test-ship 2 200 4 1]])
    (update missiles for #test-ship)
	(list of missiles [[3639 4639 315 499 #test-ship 1 200 4 1]])
    (update missiles for #test-ship)
	(list of missiles [[3279 4279 315 499 #test-ship 0 200 4 1]])
    (update missiles for #test-ship)
    (#test-ship shields 500)
	(#test-ship energy 932)
	(#test-ship length of systems 2)
	(list of missiles [])

#volley-loses-tracking
(test *)
(run *)
    (turn #test-ship to heading 30)
	(accelerate #test-ship to speed 499)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
    (move #test-ship on course and speed)
	(update missiles for #test-ship)
    (#test-ship shields 500)
	(#test-ship length of systems 2)
	(list of missiles [])

#volley-loses-tracking-when-target-destroyed
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3444 4544] at #near-target)
	(list of missiles [[3444 4544 315 499 #near-target 2 200 4 1]])
	(destroy #near-target)
	(list of missiles [])

#bfs-test-ship
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(#test-ship best functioning sensor for target 1 into
	    [#sensor 2 4 [360 #up #down]])

#test-ship-locks-onto-incoming-missiles
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(#test-ship has sensor lock on 1)

#test-ship-sensor-4-on-missiles
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(#test-ship sensor value for target 1 into 4)

#test-ship-needs-sensor-2-on-missiles
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(#test-ship needs sensor level 2 to see 1)

#manual-point-defence-test-ship
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
	(list of missiles [[3544 4444 225 499 #test-ship 2 200 4 1]])
	(#test-ship fires #projector at target 1 using 10)
	(list of missiles [[3544 4444 225 499 #test-ship 2 200 3 1]])

(use q7)
    (move #distant-target to position [3644 4744])
	(turn #distant-target to face #test-ship)

#dont-fire-not-bearing-missiles
(test *)
(run *)
    (use q7)
    (#distant-target fires #missile at target #test-ship using 1)
	(list of missiles [])

#fire-aft-missiles
(test *)
(run *)
    (use q7)
	(turn #distant-target away from #test-ship)
    (#distant-target fires #missile at target #test-ship using 1)
	(list of missiles [[3644 4744 315 255 #test-ship 3 200 1 1]])

#fire-too-many-aft-missiles
(test *)
(run *)
    (use q7)
	(turn #distant-target away from #test-ship)
    (#distant-target fires #missile at target #test-ship using 2)
	(list of missiles [[3644 4744 315 255 #test-ship 3 200 1 1]])

#dont-fire-aft-missiles-at-missiles
(test *)
(run *)
    (use q7)
	(turn #distant-target away from #test-ship)
    (launch 4 missiles of 499 2 200 from [3444 4544] at #distant-target)
	(#distant-target fires #missile at target 1 using 1)
	(list of missiles [[3444 4544 135 499 #distant-target 2 200 4 1]])

#fire-q7-with-200-and-2-bow
(test *)
(run *)
    (use q7)
    (#distant-target fires at #test-ship using 200 energy and 2 ammo)
	(#test-ship speed 0) %% collapser hit
	(#test-ship shields 402)
	(#test-ship energy 782)
	(#test-ship length of systems 3)
	(#distant-target energy 2800)
	(#distant-target ammo 8)
	(list of missiles [])

#fire-q7-with-200-and-2-stern
(test *)
(run *)
    (use q7)
	(turn #distant-target away from #test-ship)
    (#distant-target fires at #test-ship using 200 energy and 2 ammo)
	(#test-ship speed 32) %% no collapsers bearing
	(#test-ship shields 257)
	(#test-ship energy 905)
	(#test-ship length of systems 3)
	(#distant-target energy 2800)
	(#distant-target ammo 7)
	(list of missiles [[3644 4744 315 255 #test-ship 3 200 1 1]])

#manual-point-defence-q7-bow
(test *)
(run *)
    (use q7)
    (launch 4 missiles of 499 2 200 from [3444 4544] at #distant-target)
	(update missiles for #distant-target)
	(list of missiles [[3644 4744 135 499 #distant-target 1 200 4 1]])
	(#distant-target fires #projector 1 at 1 using 30)
	(list of missiles [[3644 4744 135 499 #distant-target 1 200 1 1]])

#manual-point-defence-q7-stern
(test *)
(run *)
    (use q7)
	(turn #distant-target away from #test-ship)
    (launch 4 missiles of 499 2 200 from [3444 4544] at #distant-target)
	(update missiles for #distant-target)
	(list of missiles [[3644 4744 135 499 #distant-target 1 200 4 1]])
    (#distant-target fires #projector 4 at 1 using 20)
    (#distant-target fires #projector 5 at 1 using 20)
    (list of missiles [])

#empty-autofire
(test *)
(run *)
	(autofire for #test-ship into [5 1])

#set-autofire
(test *)
(run *)
    (set autofire for #test-ship to [[#projector 1]])
	(autofire for #test-ship into [5 1 [#projector 1]])

#clear-autofire
(test *)
(run *)
    (set autofire for #test-ship to [[#projector 1]])
    (clear autofire for #test-ship)
	(autofire for #test-ship into [5 1])

#set-autofire-energy
(test *)
(run *)
    (set autofire for #test-ship to 10 16383)
	(autofire for #test-ship into [10 1])

#set-autofire-ammo
(test *)
(run *)
    (set autofire for #test-ship to 16383 2)
	(autofire for #test-ship into [5 2])

#set-autofire-q7
(test *)
(run *)
    (set autofire for #distant-target to
	    [[#projector 2] [#projector 3] [#projector 4] [#projector 5]])
	(autofire for #distant-target into
        [5 1 [#projector 2] [#projector 3] [#projector 4] [#projector 5]])

#q7-autofire-energy-weapons-at-ships
(test *)
(run *)
    (set autofire for #distant-target to
	    [[#projector 2] [#projector 3] [#projector 4] [#projector 5]])
	(#distant-target autofire energy weapons
        [[#projector 2] [#projector 3] [#projector 4] [#projector 5]])

#q7-autofire-ammo-weapons-at-ships
(test *)
(run *)
    (set autofire for #distant-target to
	    [[#projector 2] [#projector 3] [#projector 4] [#projector 5]])
	(#distant-target autofire ammo weapons [])

#test-ship-autofire-at-ships
(test *)
(run *)
    (set autofire for #test-ship to [[#projector 1]])
    (set autofire for #test-ship to 100 16383)
    (#test-ship autofires)
	(#closest-target shields 150)

(assert $Ship has $Energy energy and $Ammo ammo)
	($Ship energy $E) %% $E
	(assert $Energy = $E)
	($Ship ammo $A) %% $A
	(assert $Ammo = $A)

#q7-autofire-bow-at-ships
(test *)
(run *)
    (use q7)
	(set autofire for #distant-target to
	    [[#projector 2] [#projector 3] [#projector 4] [#projector 5]])
	(#distant-target autofires)
    (#test-ship shields 487)
    (assert #distant-target has 2990 energy and 8 ammo)

#q7-autofire-stern-at-ships
(test *)
(run *)
    (use q7)
	(turn #distant-target away from #test-ship)
	(set autofire for #distant-target to
	    [[#projector 2] [#projector 3] [#projector 4] [#projector 5]])
	(#distant-target autofires)
    (#test-ship shields 467)
    (assert #distant-target has 2975 energy and 8 ammo)

#closest-incoming-volley
(test *)
(run *)
    (launch 4 missiles of 499 2 200 from [3444 4544] at #neutral-ship)
    (launch 4 missiles of 499 2 200 from [3644 4544] at #test-ship)
    (launch 4 missiles of 499 2 200 from [3544 4444] at #test-ship)
    (closest incoming volley to #test-ship into 3)

#closest-incoming-volley-in-arc
(test *)
(run *)
    (use q7)
    (launch 2 missiles of 1097 2 500 from [3444 4544] at #closest-target)
    (launch 2 missiles of 1097 2 500 from [3444 4544] at #distant-target)
	(closest incoming volley to #distant-target in arc 1 into 2)

#closest-incoming-volley-isnt-in-arc
(test *)
(run *)
    (use q7)
    (launch 2 missiles of 1097 2 500 from [3444 4544] at #closest-target)
    (launch 2 missiles of 1097 2 500 from [3444 4544] at #distant-target)
	(closest incoming volley to #distant-target in arc 7 into 0)

#closest-incoming-volley-in-compound-arc
(test *)
(run *)
    (use q7)
    (launch 2 missiles of 1097 2 500 from [3444 4544] at #closest-target)
    (launch 2 missiles of 1097 2 500 from [3444 4544] at #distant-target)
	(closest incoming volley to #distant-target in arc [6 7 8 1 2 3] into 2)

#q7-autofire-bow-at-missiles
(test *)
(run *)
    (use q7)
    (launch 2 missiles of 1097 2 500 from [3444 4544] at #closest-target)
    (launch 2 missiles of 1097 2 500 from [3444 4544] at #distant-target)
	(set autofire for #distant-target to
	    [[#projector 2] [#projector 3] [#projector 4] [#projector 5]])
	(#distant-target autofires)
    (#test-ship shields 500)
	(list of missiles [[3444 4544 45 1097 #closest-target 2 500 2 1]])

#q7-autofire-stern-at-missiles
(test *)
(run *)
    (use q7)
    (launch 2 missiles of 1097 2 500 from [3444 4544] at #closest-target)
    (launch 2 missiles of 1097 2 500 from [3444 4544] at #distant-target)
	(turn #distant-target away from #test-ship)
	(set autofire for #distant-target to
	    [[#projector 2] [#projector 3] [#projector 4] [#projector 5]])
	(#distant-target autofires)
    (#test-ship shields 486)
	(list of missiles [[3444 4544 45 1097 #closest-target 2 500 2 1]])

#q7-autofire-all-around
(test *) %% 3644 4744
(run *)
    (use q7)
    (launch 2 missiles of 1097 2 500 from [3444 4544] at #closest-target)
    (launch 2 missiles of 1097 2 500 from [3444 4544] at #distant-target)
    (launch 2 missiles of 1097 2 500 from [3744 4544] at #distant-target)
    (launch 2 missiles of 1097 2 500 from [3544 4844] at #distant-target)
	(turn #distant-target away from #test-ship)
	(set autofire for #distant-target to
	    [[#projector 2] [#projector 3] [#projector 4] [#projector 5]])
	(#distant-target autofires)
    (#test-ship shields 500)
	(list of missiles [
		[3444 4544 45 1097 #closest-target 2 500 2 1]
		[3444 4544 135 1097 #distant-target 2 500 1 2]])
