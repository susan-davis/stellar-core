%% dgdebug -u dice-lite-tests.dg dice-lite.dg unit.dg stdlib.dg

(list of tests [
	#one-die
	#two-dice
	#three-dice
    ])

(set up $)	(reset randomness)

%%-----------------------------------------------------------------------------

(1d6 $N times)
	(if) ($N > 0) (then)
		(1d6 $Roll)
		($Roll > 0) ($Roll < 7)
		($N minus 1 into $NMinusOne)
		(1d6 $NMinusOne times)
	(endif)

(test #one-die)
	(1d6 1000 times)

(2d6 $N times)
	(if) ($N > 0) (then)
		(2d6 $Roll)
		($Roll > 1) ($Roll < 13)
		(2d6 $A $B)
		($A > 0) ($A < 7)
		($B > 0) ($B < 7)
		(d6 times d6 $Multiple)
		($Multiple > 0) ($Multiple < 37)
		($N minus 1 into $NMinusOne)
		(2d6 $NMinusOne times)
	(endif)

(test #two-dice)
	(2d6 1000 times)

(3d6 $N times)
	(if) ($N > 0) (then)
		(3d6 $Roll)
		($Roll > 2) ($Roll < 19)
		(3d6 $A $B $C)
		($A > 0) ($A < 7)
		($B > 0) ($B < 7)
		($C > 0) ($C < 7)
		($N minus 1 into $NMinusOne)
		(3d6 $NMinusOne times)
	(endif)

(test #three-dice)
	(3d6 1000 times)
