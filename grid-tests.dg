	#next-square-northeast
	#next-square-east
	#next-square-southeast
	#next-square-south
	#next-square-southwest
	#next-square-west
	#next-square-northwest
	#next-coordinates-north-inverted
	#next-coordinates-northeast-inverted
	#next-coordinates-east-inverted
	#next-coordinates-southeast-inverted
	#next-coordinates-south-inverted
	#next-coordinates-southwest-inverted
	#next-coordinates-west-inverted
	#next-coordinates-northwest-inverted
	#next-square-north-inverted
	#next-square-northeast-inverted
	#next-square-east-inverted
	#next-square-southeast-inverted
	#next-square-south-inverted
	#next-square-southwest-inverted
	#next-square-west-inverted
	#next-square-northwest-inverted
	#7-squares-north
	#6-squares-northeast
	#2-squares-east
	#5-squares-southeast
	#20-squares-south
	#24-squares-southwest
	#50-squares-west
	#4-squares-northwest
	#11-squares-east
	#11-squares-north
	#7-squares-north-inverted
