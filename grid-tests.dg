%% ----------------------------------------------------------------------

#test-ship
(grid object *)
(* initial position [344 454 315])

#closest-target
(grid object *)
(* initial position [354 444 0])

#near-target
(grid object *)
(* initial position [314 424 0])

#far-target
(grid object *)
(* initial position [424 314 0])

#distant-target
(grid object *)
(* initial position [154 984 0])

#non-grid-object
(* initial position [374 474 0])

(set up $)
	(now) ~(x increases west)
	(now) (y increases south)
    (exhaust) {
        *(grid object $Object)
        ($Object initial position $Position)
		(now) ($Object position $Position)
	}

%% ----------------------------------------------------------------------

(test #max-coords)
	(maximum coordinate value 1260)

(test #max-coords-on-map)
	(position [1260 1260] is on the map)

(test #max-coords-plus-one-not-on-map)
	(position [1261 1261] is off the map)

(test #maxint-not-on-map)
	(position [16383 16383] is off the map)

(test #offset-on-map)
	(position [100 100] is on the map)

(test #offset-minus-one-not-on-map)
	(position [99 99] is off the map)

(test #position-schema)
	(#test-ship x 344)
	(#test-ship y 454)

(test #place-ship)
	(place #test-ship at [500 500])
	(#test-ship x 500)
	(#test-ship y 500)

(test #target-on-map)
    (#closest-target is on the map)

(test #remove-target)
	(remove #closest-target from the map)
    ~(#closest-target is on the map)

(test #restore-removed-target)
    (remove #closest-target from the map)
	(place #closest-target at [334 454])
	(#closest-target x 334)
	(#closest-target y 454)

(test #position-for-removed-target)
	(remove #closest-target from the map)
	(#closest-target position [16383 16383 0])

(test #object-at-ship-position)
	(#test-ship initial position $Here)
	(object at $Here into $Obj)
	(assert $Obj = #test-ship)

(test #object-next-to-ship-position)
	~(object at [334 555] into $)

(test #objects-at-closest-target)
	(#closest-target position $There)
	(object at $There into #closest-target)

(test #object-at-near-target)
	(#near-target position $Here)
	(object at $Here into #near-target)

(test #object-at-far-target)
	(#far-target position $Here)
	(object at $Here into #far-target)

(test #object-at-empty-position)
	~(object at [895 895] into $Obj)
	~(bound $Obj)

(test #next-coordinates-north)
	(next coordinates #north from 5 5 into 5 4)

(test #next-coordinates-northeast)
	(next coordinates #northeast from 5 5 into 6 4)

(test #next-coordinates-east)
	(next coordinates #east from 5 5 into 6 5)

(test #next-coordinates-southeast)
	(next coordinates #southeast from 5 5 into 6 6)

(test #next-coordinates-south)
	(next coordinates #south from 5 5 into 5 6)

(test #next-coordinates-southwest)
	(next coordinates #southwest from 5 5 into 4 6)

(test #next-coordinates-west)
	(next coordinates #west from 5 5 into 4 5)

(test #next-coordinates-northwest)
	(next coordinates #northwest from 5 5 into 4 4)

(test #next-square-north)
	(next square #north from [344 454] into [344 453])

(test #next-square-northeast)
	(next square #northeast from [344 454] into [345 453])

(test #next-square-east)
	(next square #east from [344 454] into [345 454])

(test #next-square-southeast)
	(next square #southeast from [344 454] into [345 455])

(test #next-square-south)
	(next square #south from [344 454] into [344 455])

(test #next-square-southwest)
	(next square #southwest from [344 454] into [343 455])

(test #next-square-west)
	(next square #west from [344 454] into [343 454])

(test #next-square-northwest)
	(next square #northwest from [344 454] into [343 453])

(test #next-coordinates-north-inverted)
	(now) (x increases west)
	(now) ~(y increases south)
	(next coordinates #north from 5 5 into 5 6)

(test #next-coordinates-northeast-inverted)
	(now) (x increases west)
	(now) ~(y increases south)
	(next coordinates #northeast from 5 5 into 4 6)

(test #next-coordinates-east-inverted)
	(now) (x increases west)
	(now) ~(y increases south)
	(next coordinates #east from 5 5 into 4 5)

(test #next-coordinates-southeast-inverted)
	(now) (x increases west)
	(now) ~(y increases south)
	(next coordinates #southeast from 5 5 into 4 4)

(test #next-coordinates-south-inverted)
	(now) (x increases west)
	(now) ~(y increases south)
	(next coordinates #south from 5 5 into 5 4)

(test #next-coordinates-southwest-inverted)
	(now) (x increases west)
	(now) ~(y increases south)
	(next coordinates #southwest from 5 5 into 6 4)

(test #next-coordinates-west-inverted)
	(now) (x increases west)
	(now) ~(y increases south)
	(next coordinates #west from 5 5 into 6 5)

(test #next-coordinates-northwest-inverted)
	(now) (x increases west)
	(now) ~(y increases south)
	(next coordinates #northwest from 5 5 into 6 6)

(test #next-square-north-inverted)
	(now) (x increases west)
	(now) ~(y increases south)
	(next square #north from [344 454] into [344 455])

(test #next-square-northeast-inverted)
	(now) (x increases west)
	(now) ~(y increases south)
	(next square #northeast from [344 454] into [343 455])

(test #next-square-east-inverted)
	(now) (x increases west)
	(now) ~(y increases south)
	(next square #east from [344 454] into [343 454])

(test #next-square-southeast-inverted)
	(now) (x increases west)
	(now) ~(y increases south)
	(next square #southeast from [344 454] into [343 453])

(test #next-square-south-inverted)
	(now) (x increases west)
	(now) ~(y increases south)
	(next square #south from [344 454] into [344 453])

(test #next-square-southwest-inverted)
	(now) (x increases west)
	(now) ~(y increases south)
	(next square #southwest from [344 454] into [345 453])

(test #next-square-west-inverted)
	(now) (x increases west)
