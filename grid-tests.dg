	(object at $Here into #far-target)

#object-at-empty-position
(test *)
(run *)
	~(object at [895 895] into $Obj)
	~(bound $Obj)

#objects-at-test-ship
(test *)
(run *)
    (objects at [344 454] into [#test-ship])

#objects-at-test-ship-with-stacking
(test *)
(run *)
    (place #closest-target at [344 454])
    (objects at [344 454] into [#test-ship #closest-target])

#number-of-objects-at-test-ship
(test *)
(run *)
    (number of objects at [344 454] into 1)

#number-of-objects-with-stacking
(test *)
(run *)
