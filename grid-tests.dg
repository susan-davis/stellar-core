(test #closest-unoccupied-square-empty)
	(closest unoccupied square to [879 1044] from [344 454] into [879 1044])

(test #closest-unoccupied-square-north)
	(closest unoccupied square to [344 454] from [344 444] into $A)
	(assert $A = [344 453])

