%% dgdebug -u grid-tests.dg grid.dg utils.dg unit.dg stdlib.dg

#test-ship
(grid object *)
(* initial position [344 454 315])

#closest-target
(grid object *)
(* initial position [354 444 0])

#near-target
(grid object *)
(* initial position [314 424 0])

#far-target
(grid object *)
(* initial position [424 314 0])

#distant-target
(grid object *)
(* initial position [154 984 0])

#non-grid-object
(* initial position [374 474 0])

(set up $)
	(now) ~(x increases west)
	(now) (y increases south)
    (exhaust) {
        *(grid object $Object)
        ($Object initial position $Position)
		(now) ($Object position $Position)
	}

%%-----------------------------------------------------------------------------

#max-coords
(test *)
(run *)
	(maximum coordinate value 1260)

#max-coords-on-map
(test *)
(run *)
	(position [1260 1260] is on the map)

#max-coords-plus-one-not-on-map
(test *)
(run *)
	(position [1261 1261] is off the map)

#maxint-not-on-map
(test *)
(run *)
	(position [16383 16383] is off the map)

#offset-on-map
(test *)
(run *)
	(position [100 100] is on the map)

#offset-minus-one-not-on-map
(test *)
(run *)
	(position [99 99] is off the map)

#position-schema
(test *)
(run *)
	(#test-ship x 344)
	(#test-ship y 454)

#place-ship
(test *)
(run *)
	(place #test-ship at [500 500])
	(#test-ship x 500)
	(#test-ship y 500)

#target-on-map
(test *)
(run *)
    (#closest-target is on the map)

#remove-target
(test *)
(run *)
	(remove #closest-target from the map)
    ~(#closest-target is on the map)

#restore-removed-target
(test *)
(run *)
    (remove #closest-target from the map)
	(place #closest-target at [334 454])
	(#closest-target x 334)
	(#closest-target y 454)

#position-for-removed-target
(test *)
(run *)
	(remove #closest-target from the map)
	(#closest-target position [16383 16383 0])

#object-at-ship-position
(test *)
(run *)
	(#test-ship initial position $Here)
	(object at $Here into $Obj)
	(assert $Obj = #test-ship)

#object-next-to-ship-position
(test *)
(run *)
	~(object at [334 555] into $)

#objects-at-closest-target
(test *)
(run *)
	(#closest-target position $There)
	(object at $There into #closest-target)

#object-at-near-target
(test *)
(run *)
	(#near-target position $Here)
	(object at $Here into #near-target)

#object-at-far-target
(test *)
(run *)
	(#far-target position $Here)
	(object at $Here into #far-target)

#object-at-empty-position
(test *)
(run *)
	~(object at [895 895] into $Obj)
	~(bound $Obj)

