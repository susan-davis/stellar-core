%% ----------------------------------------------------------------------

#test-ship
(grid object *)
(* initial state [344 454 315])

#closest-target
(grid object *)
(* initial state [354 444 0])

#near-target
(grid object *)
(* initial state [314 424 0])

#far-target
(grid object *)
(* initial state [424 314 0])

#distant-target
(grid object *)
(* initial state [154 984 0])

#non-grid-object
(* initial state [374 474 0])

(set up $)
        (exhaust) {
            *(grid object $Object)
            ($Object initial state $State)
            (now) ($Object state $State)
		}
%% ----------------------------------------------------------------------

(test #state-schema)
	(#test-ship x 344)
	(#test-ship y 454)
	(#test-ship heading 315)

(test #place-at)

(test #target-on-map)
    (#closest-target is on the map)

(test #remove-target)
	(remove #closest-target from the map)
    ~(#closest-target is on the map)

(test #drag-removed-target)
	(remove #closest-target from the map)
	~(drag #closest-target to position [334 454])

(test #move-removed-target)
	(remove #closest-target from the map)
	~(move #closest-target to position [334 454])
	(#closest-target heading 0)

(test #turn-removed-target)
    (remove #closest-target from the map)
	(turn #closest-target to heading 315)
	(#closest-target heading 315)

(test #restore-removed-target)
    (remove #closest-target from the map)
	(place #closest-target at [334 454])
	(#closest-target x 334)
	(#closest-target y 454)

(test #position-for-removed-target)
	(remove #closest-target from the map)
	(#closest-target state [16383 16383 0])

(test #object-at-ship-position)
	(#test-ship initial state $Here)
	(object at $Here into $Obj)
	(assert $Obj = #test-ship)

(test #object-next-to-ship-position)
	~(object at [334 555] into $)

(test #objects-at-closest-target)
	(#closest-target state $There)
	(object at $There into #closest-target)

(test #object-at-near-target)
	(#near-target state $Here)
	(object at $Here into #near-target)

(test #object-at-far-target)
	(#far-target state $Here)
	(object at $Here into #far-target)

(test #object-at-empty-position)
	~(object at [895 895] into $Obj)
	~(bound $Obj)

(test #scale-under-10)
