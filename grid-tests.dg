%% dgdebug -u grid-tests.dg grid.dg utils.dg unit.dg stdlib.dg

#test-ship
(grid object *)
(* initial position [344 454 315])

#closest-target
(grid object *)
(* initial position [354 444 0])

#near-target
(grid object *)
(* initial position [314 424 0])

#far-target
(grid object *)
(* initial position [424 314 0])

#distant-target
(grid object *)
(* initial position [154 984 0])

#non-grid-object
(* initial position [374 474 0])

(big numbers)
    (now) (storing positions in units)
    (exhaust) {
        *(grid object $Object)
        ($Object initial position $Position)
		([$X $Y | $Tail] = $Position)
		($X times 10 into $XUnits)
		($XUnits plus 4 into $NewX) %% put them in the middle of the square
		($Y times 10 into $YUnits)
		($YUnits plus 4 into $NewY)
		([$NewX $NewY | $Tail] = $NewPosition)
		(now) ($Object position $NewPosition)
	}

(inverted map)
    (now) (x increases west)
    (now) ~(y increases south)

(reset map)
	(now) ~(x increases west)
	(now) (y increases south)
	(now) ~(storing positions in units)
	(now) (map size 1170)
	(now) (map offset 100)
	(now) (stacking limit 16383)

(set up $)
    (reset map)
    (exhaust) {
        *(grid object $Object)
        ($Object initial position $Position)
		(now) ($Object position $Position)
	}

