	(number of objects at [344 454] into 2)

#another-object-can-move-to-test-ship
(test *)
(run *)
    (another object can move to [344 454])

#another-object-cant-move-to-test-ship
(test *)
(run *)
    (now) (stacking limit 1)
    ~(another object can move to [344 454])

#enforce-stacking-limit
(test *)
(run *)
    (now) (stacking limit 1)
    ~(place #closest-target at [344 454])

