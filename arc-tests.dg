#dont-hit-closest-target-fa
(test *)
(run *)    ~(fire from #test-ship to #closest-target is in arc [1 8])

#hit-near-target-fa
(test *)
(run *)    (fire from #test-ship to #near-target is in arc [1 8])

#dont-hit-far-target-fa
(test *)
(run *)    ~(fire from #test-ship to #far-target is in arc [1 8])

#dont-hit-distant-target-fa
(test *)
(run *)    ~(fire from #test-ship to #distant-target is in arc [1 8])

#hit-closest-target-rs
(test *)
(run *)    (fire from #test-ship to #closest-target is in arc [1 2 3 4])

#hit-near-target-rs
(test *)
(run *)    (fire from #test-ship to #near-target is in arc [1 2 3 4])

#hit-far-target-rs
(test *)
(run *)    (fire from #test-ship to #far-target is in arc [1 2 3 4])

#dont-hit-distant-target-rs
(test *)
(run *)    ~(fire from #test-ship to #distant-target is in arc [1 2 3 4])

#hit-closest-target-360
(test *)
(run *)    (fire from #test-ship to #closest-target is in arc 360)

#hit-near-target-360
(test *)
(run *)    (fire from #test-ship to #near-target is in arc 360)

#hit-far-target-360
(test *)
(run *)    (fire from #test-ship to #far-target is in arc 360)

#hit-distant-target-360
(test *)
(run *)    (fire from #test-ship to #distant-target is in arc [360])

#dont-hit-closest-target-0
(test *)
(run *)    ~(fire from #test-ship to #closest-target is in arc 0)

#hit-near-target-0
(test *)
(run *)    (fire from #test-ship to #near-target is in arc [0])

#dont-hit-far-target-0
(test *)
(run *)    ~(fire from #test-ship to #far-target is in arc 0)

#dont-hit-distant-target-0
(test *)
(run *)    ~(fire from #test-ship to #distant-target is in arc 0)

#dont-hit-closest-target-odd
(test *)
(run *)    ~(fire from #test-ship to #closest-target is in arc [#north 6])

