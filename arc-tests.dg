(run *)    ~(fire from #test-ship to #far-target is in arc [#north 6])

#hit-distant-target-odd
(test *)
(run *)    (fire from #test-ship to #distant-target is in arc [#north 6])

#arc-projector
(test *)
(run *)    (#test-ship #projector 1 arc [360 #up])

#arc-tractor
(test *)
(run *)    (#test-ship #tractor 1 arc [4 5])

#arc-mtd
(test *)
(run *)    (#test-ship #mtd 1 arc #down)

#torpedo-0
(test *)
(run *)    (#test-ship #torpedo 1 bears on angle 0)

#torpedo-44
(test *)
(run *)    (#test-ship #torpedo 1 bears on angle 44)

#torpedo-45
(test *)
(run *)    (#test-ship #torpedo 1 bears on angle 45)

#torpedo-46
(test *)
(run *)    ~(#test-ship #torpedo 1 bears on angle 46)

#torpedo-135
(test *)
(run *)    ~(#test-ship #torpedo 1 bears on angle 135)

#torpedo-314
(test *)
(run *)    ~(#test-ship #torpedo 1 bears on angle 314)

#torpedo-315
