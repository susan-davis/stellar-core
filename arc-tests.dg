%% dgdebug -q arc-tests.dg arc.dg sectored-grid.dg unit.dg stdlib.dg

(list of tests [
	#firing-arc-closest-target
	#firing-arc-near-target
	#firing-arc-far-target
	#firing-arc-distant-target
	#shield-direction-closest-target
	#shield-direction-near-target
	#shield-direction-far-target
	#shield-direction-distant-target
	#due-northwest
	#due-north
	#due-northeast
	#due-east
	#due-southeast
	#due-south
	#due-southwest
	#due-west
	#fa-0
	#fa-44
	#fa-45
	#fa-46
	#fa-135
	#fa-314
	#fa-315
	#fa-316
	#fa-360
	#arc0-0
	#arc0-1
	#arc0-359
	#arc0-360
	#arc46-0
	#arc46-23
	#arc46-24
	#arc46-336
	#arc46-337
	#arc360-0
	#arc360-45
	#arc360-90
	#arc360-180
	#arc360-270
	#dont-hit-closest-target-fa
	#hit-near-target-fa
	#dont-hit-far-target-fa
	#dont-hit-distant-target-fa
	#hit-closest-target-rs
	#hit-near-target-rs
	#hit-far-target-rs
	#dont-hit-distant-target-rs
	#hit-closest-target-360
	#hit-near-target-360
	#hit-far-target-360
	#hit-distant-target-360
	#dont-hit-closest-target-0
	#hit-near-target-0
	#dont-hit-far-target-0
	#dont-hit-distant-target-0
	])

%% ----------------------------------------------------------------------

#test-ship
(grid object *)
(* state is [344 454 315])

#closest-target
(grid object *)
(* state is [354 444 0])

#near-target
(grid object *)
(* state is [314 424 0])

#far-target
(grid object *)
(* state is [424 314 0])

#distant-target
(grid object *)
(* state is [154 984 0])

#non-grid-object
(* state is [374 474 0])

#sun
(grid object *)
(* state is [577 577 0])

#planet
(grid object *)
(* state is [575 575 0])

#other-planet
(grid object *)
(* state is [573 573 0])

(clean up $)
	   (now) (#test-ship state is [344 454 315])
	   (now) (#closest-target state is [354 444 0])

%% ----------------------------------------------------------------------

(test #firing-arc-closest-target)
      (firing arc from #test-ship to #closest-target into 2)

(test #firing-arc-near-target)
      (firing arc from #test-ship to #near-target into 1)

(test #firing-arc-far-target)
      (firing arc from #test-ship to #far-target into 2)

(test #firing-arc-distant-target)
      (firing arc from #test-ship to #distant-target into 6)

(test #shield-direction-closest-target)
      (shield direction for #closest-target against #test-ship into #east)

(test #shield-direction-near-target)
      (shield direction for #near-target against #test-ship into #north)

(test #shield-direction-far-target)
      (shield direction for #far-target against #test-ship into #east)

(test #shield-direction-distant-target)
      (shield direction for #distant-target against #test-ship into #west)

(position $SX $SY $X $Y should have $Angle $Arc $Dir)
	  (drag #closest-target to $SX $SY $X $Y)
	  (firing arc from #test-ship to #closest-target into $Arc)
	  (shield direction for #closest-target against #test-ship into $Dir)
	  (angle from #test-ship to #closest-target into $Angle)

(test #due-northwest)
      (position 3 4 4 5 should have 0 1 #north)

(test #due-north)
      (position 3 4 5 5 should have 45 1 #north)

(test #due-northeast)
%%	  (position 3 4 6 5 should have 90 2 #east) %% weirdly gives 42
	  (position 3 4 7 4 should have 90 2 #east)

(test #due-east)
      (position 3 4 6 6 should have 135 3 #east)

(test #due-southeast)
      (position 3 4 6 7 should have 180 5 #south)

(test #due-south)
      (position 3 4 5 7 should have 225 6 #west)

(test #due-southwest)
      (position 3 4 4 7 should have 270 7 #west)

(test #due-west)
      (position 3 4 4 6 should have 315 8 #north)

(test #fa-0)
	  (arc [1 8] contains angle 0)

(test #fa-44)
	  (arc [1 8] contains angle 44)

(test #fa-45)
	  (arc [1 8] contains angle 45)

(test #fa-46)
	  ~(arc [1 8] contains angle 46)

(test #fa-135)
	  ~(arc [1 8] contains angle 135)

(test #fa-314)
	  ~(arc [1 8] contains angle 314)

(test #fa-315)
	  (arc [1 8] contains angle 315)

(test #fa-316)
	  (arc [1 8] contains angle 316)

(test #fa-360)
	  (arc [1 8] contains angle 360)

(test #arc0-0)
	  (arc 0 contains angle 0)

(test #arc0-1)
	  ~(arc 0 contains angle 1)

(test #arc0-359)
	  ~(arc 0 contains angle 359)

(test #arc0-360)
	  (arc 0 contains angle 360)

(test #arc46-0)
	  (arc 46 contains angle 0)

(test #arc46-23)
	  (arc [46] contains angle 23)

(test #arc46-24)
	  ~(arc 46 contains angle 24)

(test #arc46-336)
	  ~(arc 46 contains angle 336)

(test #arc46-337)
	  (arc 46 contains angle 337)

(test #arc360-0)
	  (arc 360 contains angle 0)

(test #arc360-45)
	  (arc [360] contains angle 45)

(test #arc360-90)
	  (arc 360 contains angle 90)

(test #arc360-180)
	  (arc [360] contains angle 180)

(test #arc360-270)
	  (arc 360 contains angle 270)

(test #dont-hit-closest-target-fa)
      ~(fire from #test-ship to #closest-target is in arc [1 8])

(test #hit-near-target-fa)
      (fire from #test-ship to #near-target is in arc [1 8])

(test #dont-hit-far-target-fa)
      ~(fire from #test-ship to #far-target is in arc [1 8])

(test #dont-hit-distant-target-fa)
      ~(fire from #test-ship to #distant-target is in arc [1 8])

(test #hit-closest-target-rs)
      (fire from #test-ship to #closest-target is in arc [1 2 3 4])

(test #hit-near-target-rs)
      (fire from #test-ship to #near-target is in arc [1 2 3 4])

(test #hit-far-target-rs)
      (fire from #test-ship to #far-target is in arc [1 2 3 4])

(test #dont-hit-distant-target-rs)
      ~(fire from #test-ship to #distant-target is in arc [1 2 3 4])

(test #hit-closest-target-360)
      (fire from #test-ship to #closest-target is in arc 360)

(test #hit-near-target-360)
      (fire from #test-ship to #near-target is in arc 360)

(test #hit-far-target-360)
      (fire from #test-ship to #far-target is in arc 360)

(test #hit-distant-target-360)
      (fire from #test-ship to #distant-target is in arc [360])

(test #dont-hit-closest-target-0)
      ~(fire from #test-ship to #closest-target is in arc 0)

(test #hit-near-target-0)
      (fire from #test-ship to #near-target is in arc 0)

(test #dont-hit-far-target-0)
      ~(fire from #test-ship to #far-target is in arc 0)

(test #dont-hit-distant-target-0)
      ~(fire from #test-ship to #distant-target is in arc 0)
