(run *)    (#test-ship #torpedo 1 bears on angle 360)

#torpedo-closest-target
(test *)
(run *)    ~(#test-ship #torpedo 1 bears on target #closest-target)

#torpedo-near-target
(test *)
(run *)    (#test-ship #torpedo 1 bears on target #near-target)

#torpedo-far-target
(test *)
(run *)    ~(#test-ship #torpedo 1 bears on target #far-target)

#torpedo-distant-target
(test *)
(run *)    ~(#test-ship #torpedo 1 bears on target #distant-target)

#bearing-on-closest-target-location
(test *)
(run *)    (#test-ship #torpedo bearing on angle 90 into [])

#bearing-on-near-target-location
(test *)
(run *)
	  (#test-ship #torpedo bearing on angle 0 into
	  		[[#torpedo 1 [1 8] 500 1 499]
			 [#torpedo 2 [1 8] 500 1 499]])

#bearing-on-far-target-location
(test *)
(run *)    (#test-ship #torpedo bearing on angle 75 into [])

#bearing-on-distant-target-location
(test *)
(run *)	   (#test-ship #torpedo bearing on angle 245 into [])

#bearing-on-closest-target
(test *)
(run *)    (#test-ship #torpedo bearing on target #closest-target into [])

#bearing-on-near-target
(test *)
(run *)
	  (#test-ship #torpedo bearing on target #near-target into
	  		[[#torpedo 1 [1 8] 500 1 499]
			 [#torpedo 2 [1 8] 500 1 499]])

#damaged-systems-dont-bear
(test *)
(run *)
	  (set repair time for #test-ship #torpedo 2 to 1)
	  (#test-ship #torpedo bearing on target #near-target into
	  		[[#torpedo 1 [1 8] 500 1 499]])

#bearing-on-far-target
(test *)
(run *)    (#test-ship #torpedo bearing on target #far-target into [])

#bearing-on-distant-target
(test *)
(run *)    (#test-ship #torpedo bearing on target #distant-target into [])

#bearing-as-ship-turns
(test *)
(run *)
	  (turn #test-ship to heading 0)
	  (#test-ship #torpedo bearing on target #closest-target into
	  		[[#torpedo 1 [1 8] 500 1 499]
			 [#torpedo 2 [1 8] 500 1 499]])
	  (#test-ship #torpedo bearing on target #near-target into
	  		[[#torpedo 1 [1 8] 500 1 499]
			 [#torpedo 2 [1 8] 500 1 499]])
	  (#test-ship #torpedo bearing on target #far-target into
	  		[[#torpedo 1 [1 8] 500 1 499]
			 [#torpedo 2 [1 8] 500 1 499]])
	  (#test-ship #torpedo bearing on target #distant-target into [])

#target-aspect-closest
(test *)
(run *)    (target aspect from #test-ship to #closest-target into #east)

#target-aspect-near
(test *)
(run *)    (target aspect from #test-ship to #near-target into #north)

#target-aspect-far
(test *)
(run *)    (target aspect from #test-ship to #far-target into #east)

#target-aspect-distant
(test *)
(run *)    (target aspect from #test-ship to #distant-target into #southwest)

#target-aspect-from-closest
(test *)
(run *)    (target aspect from #closest-target to #test-ship into #north)

#target-aspect-from-near
(test *)
(run *)    (target aspect from #near-target to #test-ship into #east)

#target-aspect-from-far
(test *)
(run *)    (target aspect from #far-target to #test-ship into #southwest)

#target-aspect-from-distant
(test *)
(run *)    (target aspect from #distant-target to #test-ship into #north)
