%% dgdebug -u arc-tests.dg test-ships.dg arc.dg sector.dg grid.dg \
%%            unit.dg stdlib.dg

(reset randomness)
(reset missiles)

(interface (code $))

(interface (ship type $))

%% ----------------------------------------------------------------------------

#test-ship-elevation
(test *)
(run *)    (#test-ship elevation 1)

#closest-target-elevation
(test *)
(run *)    (#closest-target elevation 2)

#near-target-elevation
(test *)
(run *)    (#near-target elevation 3)

#far-target-elevation
(test *)
(run *)    (#far-target elevation 4)

#distant-target-elevation
(test *)
(run *)    (#distant-target elevation 5)

#firing-arc-closest-target
(test *)
(run *)    (firing arc from #test-ship to #closest-target into 2)

#firing-arc-near-target
(test *)
(run *)    (firing arc from #test-ship to #near-target into 1)

#firing-arc-far-target
(test *)
(run *)    (firing arc from #test-ship to #far-target into 2)

#firing-arc-distant-target
(test *)
(run *)    (firing arc from #test-ship to #distant-target into 6)

#firing-arc-same-position
(test *)
(run *)
    (#test-ship position $Pos)
	(drag #closest-target to position $Pos)
	(firing arc from #test-ship to #closest-target into #up)
	(firing arc from #closest-target to #test-ship into #down)

#shield-direction-same-position
(test *)
(run *)
    (#test-ship position $Pos)
	(drag #closest-target to position $Pos)
	(#test-ship is at the same position as #closest-target)
	(shield direction for #test-ship against #closest-target into #down)
	(shield direction for #closest-target against #test-ship into #up)

#shield-direction-closest-target
(test *)
(run *)    (shield direction for #closest-target against #test-ship into #east)

#shield-direction-near-target
(test *)
(run *)    (shield direction for #near-target against #test-ship into #north)

#shield-direction-far-target
(test *)
(run *)    (shield direction for #far-target against #test-ship into #east)

#shield-direction-distant-target
(test *)
(run *)    (shield direction for #distant-target against #test-ship into #west)

(position $Pos should have $Angle $Arc $Dir)
	  (drag #closest-target to position $Pos)
	  (firing arc from #test-ship to #closest-target into $Arc)
	  (shield direction for #closest-target against #test-ship into $Dir)
	  (angle from #test-ship to #closest-target into $Angle)

#due-northwest
(test *)
(run *)    (position [3344 4444] should have 0 1 #north)

#due-north
(test *)
(run *)    (position [3444 4444] should have 45 1 #north)

#due-northeast
(test *)
(run *)    (position [3544 4444] should have 90 2 #east)

#due-east
(test *)
(run *)    (position [3544 4544] should have 135 3 #east)

#due-southeast
(test *)
(run *)    (position [3544 4644] should have 180 5 #south)

#due-south
(test *)
(run *)    (position [3444 4644] should have 225 6 #west)

#due-southwest
(test *)
(run *)    (position [3344 4644] should have 270 7 #west)

#due-west
(test *)
(run *)    (position [3344 4544] should have 315 8 #north)

#fa-0
(test *)
(run *)    (arc [1 8] contains angle 0)

#fa-44
(test *)
(run *)    (arc [1 8] contains angle 44)

#fa-45
(test *)
(run *)    (arc [1 8] contains angle 45)

#fa-46
(test *)
(run *)    ~(arc [1 8] contains angle 46)

#fa-135
(test *)
(run *)    ~(arc [1 8] contains angle 135)

#fa-314
(test *)
(run *)    ~(arc [1 8] contains angle 314)

#fa-315
(test *)
(run *)    (arc [1 8] contains angle 315)

#fa-316
(test *)
(run *)    (arc [1 8] contains angle 316)

#fa-360
(test *)
(run *)    (arc [1 8] contains angle 360)

