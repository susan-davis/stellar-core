(set up $)
	 (exhaust) {
	     *(grid object $Ship)
	     ($Ship initial state $State)
	     (now) ($Ship state $State) %% add this to (initialize $ as $)
		 ($Ship class $Class)
	 	 (initialize $Ship as $Class)
	 }
	 (decrease energy for #test-ship by 68)
	 (reset randomness)
