(* position [7664 7664])
(* state #union)

#enemy-base
(base *)
(code *)	\#
(* position [2114 2114])
(* state #quellan)

(set up $)
     (now) ~(x increases west)
	 (now) (y increases south)
	 (now) (storing positions in units)
	 (now) (map offset 100)
	 (now) (map size 1100)
	 (exhaust) {
	     *(ship $Ship)
	     ($Ship initial position $Position)
	     (now) ($Ship position $Position)
	     ($Ship initial state $State)
	     (now) ($Ship state $State)
	     (if) ($Ship initial systems $Systems) (then)
	     	 (now) ($Ship systems $Systems)
		 (else)
			 (now) ($Ship systems [])
		 (endif)
		 ($Ship class $Class)
		 (initialize $Ship as $Class)
	 }
	 (#test-ship initial state $Initial)
	 (now) (#test-ship state $Initial)
	 (reset missiles)
	 (reset randomness)

