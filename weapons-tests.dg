%% dgdebug -u weapons-tests.dg test-ships.dg weapons.dg sensor.dg damage.dg
%% 		   	  arc.dg maneuver.dg schema.dg sector.dg grid.dg unit.dg stdlib.dg

(interface (ship type $))  %% silence warnings

(interface (code $))       %% silence warnings

(reset missiles)

%%-----------------------------------------------------------------------------

#weapons-bearing-on-closest-target-location
(test *)
(run *)
    (#test-ship weapons bearing on angle 90 into
			[[#projector 1 100 [360 #up] 1 141]])

#weapons-bearing-on-near-target-location
(test *)
(run *)
    (#test-ship weapons bearing on angle 0 into
			[[#projector 1 100 [360 #up] 1 141]
			[#torpedo 1 500 [1 8] 1 499 1097]
			[#torpedo 2 500 [1 8] 1 499 1097]])

#weapons-bearing-on-closest-target
(test *)
(run *)
    (#test-ship weapons bearing on target #closest-target into
			[[#projector 1 100 [360 #up] 1 141]])

#weapons-bearing-on-near-target
(test *)
(run *)
    (#test-ship weapons bearing on target #near-target into
			[[#projector 1 100 [360 #up] 1 141]
			[#torpedo 1 500 [1 8] 1 499 1097]
			[#torpedo 2 500 [1 8] 1 499 1097]])

#damaged-weapons-dont-bear
(test *)
(run *)
	(damage #test-ship system #torpedo 1 with 50 from #north)
    (#test-ship weapons bearing on target #near-target into
			[[#projector 1 100 [360 #up] 1 141]
			[#torpedo 2 500 [1 8] 1 499 1097]])

(assert $Ship has $Energy energy and $Ammo ammo)
	($Ship energy $E) %% $E
	(assert $Energy = $E)
	($Ship ammo $A) %% $A
	(assert $Ammo = $A)

#dont-projector-self
(test *)
(run *)
	(#test-ship fires #projector at target #test-ship using 100)
	(assert #test-ship has 932 energy and 10 ammo)
	(#test-ship shields 500)

#dont-projector-destroyed-target
(test *)
(run *)
	(destroy #closest-target)
	(#test-ship fires #projector at target #closest-target using 100)
	(assert #test-ship has 932 energy and 10 ammo)

#dont-fire-projector-at-far-target
(test *)
(run *)
	(#test-ship fires #projector at target #far-target using 100)
	(assert #test-ship has 932 energy and 10 ammo)
	(#far-target shields 250)

#dont-fire-projector-at-distant-target
(test *)
(run *)
	(#test-ship fires #projector at target #distant-target using 100)
	(assert #test-ship has 932 energy and 10 ammo)
	(#distant-target shields 500)

#fire-projector-with-0
(test *)
(run *)
	(#test-ship fires #projector at target #near-target using 0)
	(assert #test-ship has 932 energy and 10 ammo)
	(#near-target shields 250)

#fire-projector-with-100
(test *)
(run *)
	(#test-ship fires #projector at target #near-target using 100)
	(assert #test-ship has 832 energy and 10 ammo)
	(#near-target shields 200)

#fire-projector-with-200
(test *)
(run *)
	(#test-ship fires #projector at target #near-target using 200)
	(assert #test-ship has 832 energy and 10 ammo)
	(#near-target shields 200)

#projector-miss
(test *)
(run *)
	(now) (3d6 list position 10)
	(#test-ship fires #projector at target #near-target using 100)
	(assert #test-ship has 832 energy and 10 ammo)
	(#near-target shields 250)

#dont-fire-projector-without-lock-on
(test *)
(run *)
    (increase repair time for #test-ship #sensor 1 by 30)
    (increase repair time for #test-ship #sensor 2 by 30)
    (increase repair time for #test-ship #sensor 3 by 30)
	(#test-ship fires #projector at target #near-target using 100)
	(assert #test-ship has 932 energy and 10 ammo)
	(#near-target shields 250)

#dont-torpedo-self
(test *)
(run *)
	(#test-ship fires #torpedo at target #test-ship using 2)
	(assert #test-ship has 932 energy and 10 ammo)
	(#test-ship shields 500)

#dont-torpedo-destroyed-target
(test *)
(run *)
	(destroy #near-target)
	(#test-ship fires #torpedo at target #near-target using 2)
	(assert #test-ship has 932 energy and 10 ammo)

#fire-torpedo-with-0
(test *)
(run *)
	(#test-ship fires #torpedo at target #near-target using 0)
	(assert #test-ship has 932 energy and 10 ammo)
	(#near-target shields 250)

#fire-torpedo-with-1
(test *)
(run *)
	(#test-ship fires #torpedo at target #near-target using 1)
	(assert #test-ship has 932 energy and 9 ammo)
	(#near-target shields 200)

#fire-torpedo-with-2
(test *)
(run *)
	(#test-ship fires #torpedo at target #near-target using 2)
	(assert #test-ship has 932 energy and 8 ammo)
	(#near-target is destroyed)

#fire-torpedo-with-4
(test *)
(run *)
	(#test-ship fires #torpedo at target #near-target using 4)
	(assert #test-ship has 932 energy and 8 ammo)
	(#near-target is destroyed)

#torpedo-miss
(test *)
(run *)
	(accelerate #near-target to gradient 6)
	(now) (3d6 list position 10)
	(#test-ship fires #torpedo at target #near-target using 2)
	(assert #test-ship has 932 energy and 8 ammo)
	(#near-target shields 250) %% both torpedoes miss

#fire-at-closest-with-100-and-2
(test *)
(run *)
	(#test-ship fires at #closest-target using 100 energy and 2 ammo)
	(#closest-target shields 150) %% hit the front shield, harder
	(assert #test-ship has 832 energy and 10 ammo) %% torpedoes out of arc

#fire-at-near-with-100-and-2
(test *)
(run *)
	(#test-ship fires at #near-target using 100 energy and 2 ammo)
	(assert #test-ship has 832 energy and 8 ammo)
	(#near-target is destroyed)

#fire-at-near-with-200-and-4
(test *)
(run *)
	(#test-ship fires at #near-target using 200 energy and 4 ammo)
	(assert #test-ship has 832 energy and 8 ammo)
	(#near-target is destroyed)

(use q7)
    (move #distant-target to position [3644 4744])
	(turn #distant-target to face #test-ship)

#fire-collapser-with-100
(test *)
(run *)
    (use q7)
	(#distant-target fires #collapser at target #test-ship using 100)
	(#test-ship speed 0)
	(#test-ship shields 402)
	(#test-ship energy 922)
	(#test-ship length of systems 3)

#fire-collapser-with-100-faster-target
(test *)
(run *)
    (use q7)
	(accelerate #test-ship to gradient 8)
	(#distant-target fires #collapser at target #test-ship using 100)
	(#test-ship speed 116)
	(#test-ship shields 500)
    (#test-ship energy 932)
	(#test-ship length of systems 2)

#max-amount-for-projector
(test *)
(run *)
    (max amount for [#projector 1 100 [360 #up #down] 1 141] into 100)

#max-amount-for-torpedo
(test *)
(run *)
    (max amount for [#torpedo 1 500 [360 #up #down] 1 499 1097] into 1)
