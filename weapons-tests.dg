%% dgdebug -u weapons-tests.dg test-targets.dg weapons.dg damage.dg arc.dg \
%% 		   	  schema.dg sectored-grid.dg unit.dg stdlib.dg

(list of tests [
	  #weapons-bearing-on-closest-target-location
	  #weapons-bearing-on-near-target-location
	  #weapons-bearing-on-closest-target
	  #weapons-bearing-on-near-target
	  #damaged-weapons-dont-bear
	  #fire-projector-with-0
	  #fire-projector-with-100
	  #fire-projector-with-200
	  #projector-miss
	  #fire-torpedo-with-0
	  #fire-torpedo-with-1
	  #fire-torpedo-with-2
	  #fire-torpedo-with-4
	  #torpedo-miss
	  #fire-projector-at-90
	  #fire-projector-at-0
	  #fire-torpedo-at-90
	  #fire-torpedo-at-0
	  #fire-at-closest-with-100
	  #fire-at-closest-with-200
	  #fire-at-near-with-100
	  #fire-at-near-with-200
	  #fire-at-closest-with-2
	  #fire-at-closest-with-4
	  #fire-at-near-with-2
	  #fire-at-near-with-4
	  #fire-at-closest-with-100-and-2
	  #fire-at-near-with-100-and-2
	  #fire-at-near-with-200-and-4
	  ])

%% ----------------------------------------------------------------------

(test #weapons-bearing-on-closest-target-location)
    (#test-ship weapons bearing on angle 90 into
			[[#projector 1 [360 #up] 100 141 3 0]])

(test #weapons-bearing-on-near-target-location)
    (#test-ship weapons bearing on angle 0 into
			[[#projector 1 [360 #up] 100 141 3 0]
			[#torpedo 1 [1 8] 1 500 2 0]
			[#torpedo 2 [1 8] 1 500 2 0]])

(test #weapons-bearing-on-closest-target)
    (#test-ship weapons bearing on target #closest-target into
			[[#projector 1 [360 #up] 100 141 3 0]])

(test #weapons-bearing-on-near-target)
    (#test-ship weapons bearing on target #near-target into
			[[#projector 1 [360 #up] 100 141 3 0]
			[#torpedo 1 [1 8] 1 500 2 0]
			[#torpedo 2 [1 8] 1 500 2 0]])

(test #damaged-weapons-dont-bear)
	(damage #test-ship system #torpedo 1 with 50)
    (#test-ship weapons bearing on target #near-target into
			[[#projector 1 [360 #up] 100 141 3 0]
			[#torpedo 2 [1 8] 1 500 2 0]])

(test #fire-projector-with-0)
	(#test-ship fires #projector at target #near-target using 0)
	(#near-target shields 250)

(test #fire-projector-with-100)
	(#test-ship fires #projector at target #near-target using 100)
	(#near-target shields 200)
	(#test-ship energy 832)

(test #fire-projector-with-200)
	(#test-ship fires #projector at target #near-target using 200)
	(#near-target shields 200)
	(#test-ship energy 832)

(test #projector-miss)
	Not implemented

(test #fire-torpedo-with-0)
	(#test-ship fires #torpedo at target #near-target using 0)
	(#near-target shields 250)

(test #fire-torpedo-with-1)
	(#test-ship fires #torpedo at target #near-target using 1)
	(#near-target shields 200)

(test #fire-torpedo-with-2)
	(#test-ship fires #torpedo at target #near-target using 2)
	(#near-target shields 150)

(test #fire-torpedo-with-4)
	(#test-ship fires #torpedo at target #near-target using 4)
	(#near-target shields 150)

(test #torpedo-miss)
	Not implemented

(test #fire-at-closest-with-100)
	Not implemented

(test #fire-at-closest-with-200)
	Not implemented

(test #fire-at-near-with-100)
	Not implemented

(test #fire-at-near-with-200)
	Not implemented

(test #fire-at-closest-with-2)
	Not implemented

(test #fire-at-closest-with-4)
	Not implemented

(test #fire-at-near-with-2)
	Not implemented

(test #fire-at-near-with-4)
	Not implemented

(test #fire-at-closest-with-100-and-2)
	Not implemented

(test #fire-at-near-with-100-and-2)
	Not implemented

(test #fire-at-near-with-200-and-4)
	Not implemented

(test #fire-projector-at-90)
	Not implemented

(test #fire-projector-at-0)
	Not implemented

(test #fire-torpedo-at-90)
	Not implemented

(test #fire-torpedo-at-0)
	Not implemented
